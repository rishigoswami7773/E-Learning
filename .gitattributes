# Auto-detect text files and normalize line endings to CRLF on Windows
* text=auto eol=crlf

# C# source files
*.cs    text eol=crlf
*.cshtml text eol=crlf
*.csproj text eol=crlf
*.json  text eol=crlf
*.md    text eol=crlf
*.css   text eol=crlf
*.js    text eol=crlf
*.html  text eol=crlf
*.txt   text eol=crlf
*.yml   text eol=crlf
*.yaml  text eol=crlf
*.xml   text eol=crlf

# Binary files — never convert
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.dll   binary
*.exe   binary
