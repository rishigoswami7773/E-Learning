@model Project_BD.Models.ContactMessage

@{
    ViewData["Title"] = "Contact Us";
}

<style>
    .contact-container {
        padding: 80px 8%;
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 60px;
        background: #f8fafc;
        min-height: 80vh;
    }

    .contact-info h1 {
        font-size: 40px;
        color: #1e293b;
        margin-bottom: 24px;
        font-weight: 800;
        letter-spacing: -1px;
    }

    .contact-info p {
        color: #64748b;
        font-size: 16px;
        line-height: 1.8;
        margin-bottom: 40px;
    }

    .info-item {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .info-icon {
        width: 48px;
        height: 48px;
        background: #eff6ff;
        color: #2563eb;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .info-text h3 {
        font-size: 16px;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .info-text p {
        margin-bottom: 0;
        font-size: 14px;
    }

    .contact-form-card {
        background: white;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.05);
        border: 1px solid #f1f5f9;
        height: min-content;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-size: 15px;
        transition: all 0.2s;
        background: #fff;
    }

    .form-control:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background: #2563eb;
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-submit:hover {
        background: #1d4ed8;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #bbf7d0;
        margin-bottom: 30px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
    }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<div class="contact-container">
    <div class="contact-info">
        <h1>Connect with Our Learning Support</h1>
        <p>Whether you're struggling with a course module or have technical issues, our administrative team is here to
            guide you directly.</p>

        <div class="info-item">
            <div class="info-icon"><i class="fas fa-envelope"></i></div>
            <div class="info-text">
                <h3>Direct Support</h3>
                <p>Your message goes directly to our admin team notifications.</p>
            </div>
        </div>

        <div class="info-item">
            <div class="info-icon"><i class="fas fa-bolt"></i></div>
            <div class="info-text">
                <h3>Response Time</h3>
                <p>We typically respond within 24 business hours.</p>
            </div>
        </div>

        <div class="info-item">
            <div class="info-icon"><i class="fas fa-shield-halved"></i></div>
            <div class="info-text">
                <h3>Secure Communication</h3>
                <p>Your data is protected by our encryption protocols.</p>
            </div>
        </div>
    </div>

    <div class="contact-form-card">
        @if (ViewBag.Success != null)
        {
            <div class="alert-success">
                <i class="fas fa-circle-check"></i>
                @ViewBag.Success
            </div>
        }

        <form asp-action="Contact" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="John Doe"
                    value="@(Context.Session.GetString("UserName") ?? "")" required>
                <span asp-validation-for="Name" style="color:red; font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="john@example.com"
                    value="@(Context.Session.GetString("UserEmail") ?? "")" required>
                <span asp-validation-for="Email" style="color:red; font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label>Subject</label>
                <input asp-for="Subject" class="form-control" placeholder="How can we help?" required>
                <span asp-validation-for="Subject" style="color:red; font-size:12px;"></span>
            </div>

            <div class="form-group">
                <label>Your Message</label>
                <textarea asp-for="Message" class="form-control" rows="5" placeholder="Write your message here..."
                    required></textarea>
                <span asp-validation-for="Message" style="color:red; font-size:12px;"></span>
            </div>

            <button type="submit" class="btn-submit">
                Send Direct Message <i class="fas fa-paper-plane"></i>
            </button>
        </form>
    </div>
</div>
