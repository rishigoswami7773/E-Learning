@model IEnumerable<Project_BD.Models.Category>

@{
    ViewData["Title"] = "Premium Learning Experience";
}

<style>
    /* Custom Home Styles */
    .hero-section {
        background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
        padding: 120px 8% 180px;
        text-align: center;
        color: white;
        position: relative;
        overflow: hidden;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&q=80&w=2070') center/cover;
        opacity: 0.1;
        mix-blend-mode: overlay;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 900px;
        margin: 0 auto;
    }

    .hero-content h1 {
        font-size: clamp(48px, 6vw, 72px);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -2px;
        margin-bottom: 24px;
        background: linear-gradient(to bottom, #ffffff, #d1d5db);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-content p {
        font-size: 20px;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 48px;
        max-width: 600px;
        margin-inline: auto;
    }

    .hero-btns {
        display: flex;
        gap: 20px;
        justify-content: center;
    }

    .btn-hero-primary {
        background: white;
        color: var(--primary);
        padding: 18px 40px;
        border-radius: 16px;
        font-weight: 800;
        text-decoration: none;
        font-size: 16px;
        transition: all 0.3s;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

    .btn-hero-secondary {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        padding: 18px 40px;
        border-radius: 16px;
        font-weight: 800;
        text-decoration: none;
        font-size: 16px;
        transition: all 0.3s;
    }

    .btn-hero-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
    }

    /* Stats Bar */
    .stats-bar {
        background: white;
        margin: -80px 8% 0;
        padding: 40px;
        border-radius: 32px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 40px;
        box-shadow: var(--shadow-lg);
        position: relative;
        z-index: 20;
    }

    .stat-item {
        text-align: center;
        border-right: 1px solid var(--border);
    }

    .stat-item:last-child {
        border: none;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        background: var(--primary-light);
        color: var(--primary);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 20px;
    }

    .stat-value {
        font-size: 32px;
        font-weight: 800;
        color: var(--text-main);
        line-height: 1;
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 14px;
        color: var(--text-muted);
        font-weight: 600;
    }

    /* Categories Section */
    .section-padding {
        padding: 120px 8%;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 60px;
    }

    .section-title {
        font-size: 14px;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 800;
        letter-spacing: 2px;
        margin-bottom: 12px;
        display: block;
    }

    .section-heading {
        font-size: 36px;
        font-weight: 800;
        color: var(--text-main);
        letter-spacing: -1px;
    }

    .category-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 32px;
    }

    .category-card {
        background: white;
        border-radius: 24px;
        padding: 32px;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    }

    .category-card:hover {
        transform: translateY(-10px);
        box-shadow: var(--shadow-lg);
        border-color: var(--primary);
    }

    .category-icon {
        width: 64px;
        height: 64px;
        background: #f1f5f9;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 24px;
        transition: all 0.3s;
    }

    .category-card:hover .category-icon {
        background: var(--primary);
        color: white;
    }

    .category-card h3 {
        font-size: 20px;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 8px;
    }

    .category-card p {
        font-size: 15px;
        color: var(--text-muted);
    }

    /* Info Section */
    .info-section {
        background: white;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 80px;
    }

    .info-image {
        position: relative;
        border-radius: 40px;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

    .info-badge {
        position: absolute;
        bottom: 40px;
        right: 40px;
        background: white;
        padding: 24px;
        border-radius: 24px;
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    /* Community / Testimonials */
    .testimonial-card {
        background: var(--bg-body);
        padding: 40px;
        border-radius: 24px;
        border: 1px solid var(--border);
    }

    .user-meta {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 24px;
    }

    .user-meta img {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
    }

    @media(max-width:768px) {
        .stats-bar {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .info-section {
            grid-template-columns: 1fr;
        }

        .hero-btns {
            flex-direction: column;
        }
    }
</style>

<section class="hero-section">
    <div class="hero-content">
        <h1>Navigate Your Future in Tech</h1>
        <p>Unlock premium courses from global industry experts. Join our community of 15,000+ learners and transform
            your career.</p>
        <div class="hero-btns">
            <a asp-controller="Course" asp-action="Index" class="btn-hero-primary">Browse All Courses <i
                    class="fas fa-arrow-right" style="margin-left: 10px;"></i></a>
            <a asp-controller="Users" asp-action="Login" class="btn-hero-secondary">Get Started Now</a>
        </div>
    </div>
</section>

<div class="stats-bar">
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-value">15k+</div>
        <div class="stat-label">Learners Worldwide</div>
    </div>
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-book-open"></i></div>
        <div class="stat-value">500+</div>
        <div class="stat-label">Premium Courses</div>
    </div>
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-certificate"></i></div>
        <div class="stat-value">120+</div>
        <div class="stat-label">Expert Instructors</div>
    </div>
    <div class="stat-item">
        <div class="stat-icon"><i class="fas fa-star" style="color: #fbbf24;"></i></div>
        <div class="stat-value">4.8/5</div>
        <div class="stat-label">Average Rating</div>
    </div>
</div>

<section class="section-padding">
    <div class="section-header">
        <div>
            <span class="section-title">Categories</span>
            <h2 class="section-heading">Explore Top Subjects</h2>
        </div>
        <a asp-controller="Course" asp-action="Index" class="btn-hero-primary"
            style="padding: 12px 24px; font-size: 14px; background: var(--bg-body); border: 1px solid var(--border); box-shadow: none;">Browse
            All Categories</a>
    </div>

    <div class="category-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var category in Model.Take(6))
            {
                <a asp-controller="Course" asp-action="Index" asp-route-categoryId="@category.CategoryId" class="category-card">
                    <div class="category-icon">
                        @if (!string.IsNullOrEmpty(category.ImageUrl))
                        {
                            <img src="@category.ImageUrl"
                                style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;" />
                        }
                        else
                        {
                            <i class="fas fa-laptop-code"></i>
                        }
                    </div>
                    <h3>@category.Name</h3>
                    <p>Master @category.Name with industry-leading modules.</p>
                </a>
            }
        }
        else
        {
            <!-- Fallback Static Categories if and only if Model is empty for demo purposes -->
            <div class="category-card">
                <div class="category-icon"><i class="fas fa-code"></i></div>
                <h3>Web Development</h3>
                <p>128+ Premium Courses</p>
            </div>
            <div class="category-card">
                <div class="category-icon"><i class="fas fa-brain"></i></div>
                <h3>Data Science</h3>
                <p>85+ Expert Modules</p>
            </div>
            <div class="category-card">
                <div class="category-icon"><i class="fas fa-palette"></i></div>
                <h3>UI/UX Design</h3>
                <p>94+ Design Paths</p>
            </div>
        }
    </div>
</section>

<section class="section-padding" style="background: #eef2ff;">
    <div class="info-section">
        <div class="info-content">
            <span class="section-title">Why Us?</span>
            <h2 class="section-heading" style="margin-bottom: 24px;">Elevate Your Career Path</h2>
            <p style="color: var(--text-muted); font-size: 18px; margin-bottom: 40px;">
                Everything you need to master new skills and achieve your professional goals. We provide curated content
                from industry giants.
            </p>

            <div style="display: grid; gap: 24px;">
                <div style="display: flex; gap: 20px;">
                    <div
                        style="width: 48px; height: 48px; background: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0;">
                        <i class="fas fa-check"></i>
                    </div>
                    <div>
                        <h4 style="font-weight: 700;">Curated Content</h4>
                        <p style="font-size: 14px; color: var(--text-muted);">Hand-picked courses designed for maximum
                            knowledge retention.</p>
                    </div>
                </div>
                <div style="display: flex; gap: 20px;">
                    <div
                        style="width: 48px; height: 48px; background: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0;">
                        <i class="fas fa-user-friends"></i>
                    </div>
                    <div>
                        <h4 style="font-weight: 700;">Mentor Support</h4>
                        <p style="font-size: 14px; color: var(--text-muted);">Get 24/7 support from experts in the
                            field.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="info-image">
            <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=2071"
                style="width: 100%; display: block;" />
            <div class="info-badge">
                <div class="user-avatar" style="width: 50px; height: 50px;">
                    <i class="fas fa-certificate"></i>
                </div>
                <div>
                    <h5 style="margin: 0; font-weight: 800;">Certified Learning</h5>
                    <p style="margin: 0; font-size: 12px; color: var(--text-muted);">Recognized worldwide</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-padding" style="background: white;">
    <div style="text-align: center; margin-bottom: 60px;">
        <span class="section-title">Success Stories</span>
        <h2 class="section-heading">From Our Community</h2>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 32px;">
        <div class="testimonial-card">
            <p style="font-size: 18px; color: var(--text-main); font-style: italic; line-height: 1.6;">
                "The E-Learning platform transformed my career. The projects and instructors are better than my college
                degree."
            </p>
            <div class="user-meta">
                <img src="https://i.pravatar.cc/150?u=sarah" />
                <div>
                    <h5 style="margin: 0; font-weight: 800;">Sarah Jenkins</h5>
                    <p style="margin: 0; font-size: 14px; color: var(--text-muted);">
                        Full Stack Engineer @@ Google
                    </p>
                </div>
            </div>
        </div>
        <div class="testimonial-card">
            <p style="font-size: 18px; color: var(--text-main); font-style: italic; line-height: 1.6;">
                "Best investment I've made for my professional growth. The community support made learning incredibly
                engaging."
            </p>
            <div class="user-meta">
                <img src="https://i.pravatar.cc/150?u=david" />
                <div>
                    <h5 style="margin: 0; font-weight: 800;">David Chen</h5>
                    <p style="margin: 0; font-size: 14px; color: var(--text-muted);">Lead Data Scientist</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-padding" style="background: #0f172a; text-align: center; color: white;">
    <div style="max-width: 600px; margin: 0 auto;">
        <h2 class="section-heading" style="color: white; margin-bottom: 24px;">Join the Revolution</h2>
        <p style="color: #94a3b8; font-size: 18px; margin-bottom: 40px;">Get weekly insights and update on latest
            designs in your inbox.</p>
        <div
            style="display: flex; gap: 12px; background: rgba(255,255,255,0.05); padding: 8px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1);">
            <input type="text" placeholder="Email address"
                style="flex: 1; background: transparent; border: none; padding: 0 20px; color: white; outline: none;" />
            <button class="btn-hero-primary" style="padding: 12px 30px; box-shadow: none;">Subscribe</button>
        </div>
    </div>
</section>

<section class="section-padding" style="text-align: center;">
    <span class="section-title">Our Campus</span>
    <h2 class="section-heading" style="margin-bottom: 60px;">Visit Us Anytime</h2>
    <div style="height: 400px; border-radius: 40px; overflow: hidden; box-shadow: var(--shadow-lg);">
        <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d118224.23467406203!2d70.78168595!3d22.30715885!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3959c908d0000001%3A0xf64f336630a91e3e!2sRK%20University!5e0!3m2!1sen!2sin!4v1709400000000!5m2!1sen!2sin"
            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy">
        </iframe>
    </div>
</section>