@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
<section class="hero">
    <h1>Welcome to E-Learning</h1>
    <p>Your gateway to knowledge and skill development</p>
    <button class="btn-primary">Browse All Courses →</button>
    <button class="btn-secondary">Get Started</button>
</section>

<section class="features">
    <h2>Why Choose E-Learning?</h2>
    <p class="subtitle">Everything you need to succeed in your learning journey</p>

    <div class="feature-cards">
        <div class="card">
            <div class="icon">📘</div>
            <h3>Wide Range of Courses</h3>
            <p>Access diverse courses across multiple subjects from beginner to advanced levels</p>
        </div>

        <div class="card">
            <div class="icon">👨‍🏫</div>
            <h3>Expert Instructors</h3>
            <p>Learn from industry professionals and experienced educators</p>
        </div>

        <div class="card">
            <div class="icon">🏆</div>
            <h3>Earn Certificates</h3>
            <p>Complete courses and quizzes to earn certificates and showcase your skills</p>
        </div>
    </div>
</section>

<section class="cta">
    <h2>Ready to Start Learning?</h2>
    <p>Join thousands of students already learning on our platform</p>
    <button class="btn-dark">Explore Courses →</button>
</section>