@model IEnumerable<Project_BD.Models.Category>

@{
    ViewData["Title"] = "Home Page";
}


<section class="hero">
    <h1>Welcome to E-Learning</h1>
    <p>Your gateway to knowledge and skill development</p>
    <div style="display: flex; gap: 15px; justify-content: center; margin-top: 30px;">
        <a asp-controller="Course" asp-action="Index" class="btn-primary"
            style="text-decoration: none; padding: 12px 25px; border-radius: 8px;">Browse All Courses →</a>
        <a asp-controller="Users" asp-action="Login" class="btn-secondary"
            style="text-decoration: none; padding: 12px 25px; border-radius: 8px; border: 1px solid white;">Get Started</a>
    </div>
</section>

@if (Model != null && Model.Any())
{
    <section style="padding: 60px 8%; background: #f8fafc;">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px;">
            <div>
                <h2 style="font-size: 28px; color: #1e293b; margin-bottom: 10px;">Top Categories</h2>
                <p style="color: #64748b;">Explore courses by subject area</p>
            </div>
            <a asp-controller="Course" asp-action="Index" style="color: #2b59ff; font-weight: 700; text-decoration: none;">View All →</a>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px;">
            @foreach (var category in Model)
            {
                <a asp-controller="Course" asp-action="Index" asp-route-categoryId="@category.CategoryId" 
                   style="text-decoration: none; color: inherit; display: block; background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.03); transition: transform 0.3s;"
                   onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <div style="height: 160px; background: #e2e8f0; position: relative;">
                        @if (!string.IsNullOrEmpty(category.ImageUrl))
                        {
                            <img src="@category.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="@category.Name" />
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 40px; color: #94a3b8;">
                                <i class="fas fa-folder-open"></i>
                            </div>
                        }
                    </div>
                    <div style="padding: 20px; text-align: center;">
                        <h3 style="font-size: 18px; color: #1e293b; margin-bottom: 5px;">@category.Name</h3>
                        <p style="font-size: 13px; color: #64748b; margin: 0;">Learn @category.Name skills from scratch</p>
                    </div>
                </a>
            }
        </div>
    </section>
}

<section class="features">
    <h2>Why Choose E-Learning?</h2>
    <p class="subtitle">Everything you need to succeed in your learning journey</p>

    <div class="feature-cards">
        <div class="card">
            <div class="icon">📘</div>
            <h3>Wide Range of Courses</h3>
            <p>Access diverse courses across multiple subjects from beginner to advanced levels</p>
        </div>

        <div class="card">
            <div class="icon">👨‍🏫</div>
            <h3>Expert Instructors</h3>
            <p>Learn from industry professionals and experienced educators</p>
        </div>

        <div class="card">
            <div class="icon">🏆</div>
            <h3>Earn Certificates</h3>
            <p>Complete courses and quizzes to earn certificates and showcase your skills</p>
        </div>
    </div>
</section>

<section style="padding: 80px 8%; background: white; text-align: center;">
    <h2 style="font-size: 32px; color: #1e293b; margin-bottom: 50px;">What Our Students Say</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
        <div
            style="background: #f8fafc; padding: 40px; border-radius: 20px; text-align: left; border: 1px solid #f1f5f9;">
            <div style="display: flex; gap: 4px; color: #f59e0b; margin-bottom: 20px;">
                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i
                    class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p style="color: #475569; font-style: italic; line-height: 1.6; margin-bottom: 25px;">
                "The ASP.NET Core course helped me land my first job as a software engineer. The curriculum is
                incredibly practical and industry-focused."
            </p>
            <div style="display: flex; align-items: center; gap: 15px;">
                <div
                    style="width: 48px; height: 48px; background: #e0e7ff; color: #4338ca; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700;">
                    JD</div>
                <div>
                    <h4 style="font-size: 16px; color: #1e293b; font-weight: 700;">John Doe</h4>
                    <p style="font-size: 13px; color: #64748b; margin: 0;">Junior Web Developer</p>
                </div>
            </div>
        </div>
        <div
            style="background: #f8fafc; padding: 40px; border-radius: 20px; text-align: left; border: 1px solid #f1f5f9;">
            <div style="display: flex; gap: 4px; color: #f59e0b; margin-bottom: 20px;">
                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i
                    class="fas fa-star"></i><i class="fas fa-star"></i>
            </div>
            <p style="color: #475569; font-style: italic; line-height: 1.6; margin-bottom: 25px;">
                "I've taken several courses on this platform. The quality of instructors and the support from the
                community are unmatched."
            </p>
            <div style="display: flex; align-items: center; gap: 15px;">
                <div
                    style="width: 48px; height: 48px; background: #fef3c7; color: #92400e; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700;">
                    AS</div>
                <div>
                    <h4 style="font-size: 16px; color: #1e293b; font-weight: 700;">Alice Smith</h4>
                    <p style="font-size: 13px; color: #64748b; margin: 0;">UI/UX Designer</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cta">
    <h2>Ready to Start Learning?</h2>
    <p>Join thousands of students already learning on our platform</p>
    <a asp-controller="Course" asp-action="Index" class="btn-dark"
        style="text-decoration: none; display: inline-block;">Explore Courses →</a>
</section>