@model Project_BD.Models.User

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Directory Registration";
}

<div class="content-header animate-fade-in">
    <h1>Directory Registration</h1>
    <p>Onboard new talent or administrative staff to the platform ecosystem.</p>
</div>

<div style="display: flex; justify-content: center; margin-top: 40px;" class="animate-fade-in"
    style="animation-delay: 0.1s;">
    <div class="card-section" style="width: 100%; max-width: 650px; padding: 40px;">
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 32px;">
            <div
                style="width: 48px; height: 48px; background: #eff6ff; color: var(--primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px;">
                <i class="fas fa-user-plus"></i>
            </div>
            <div>
                <h3 style="font-size: 20px; font-weight: 800; color: var(--text-main);">Entity Attributes</h3>
                <p style="font-size: 13px; color: var(--text-muted);">Please provide the following credentials for the
                    new account.</p>
            </div>
        </div>

        <form asp-action="CreateUser" method="post">
            <div asp-validation-summary="ModelOnly"
                style="color: var(--danger); font-size: 13px; font-weight: 700; background: #fef2f2; padding: 12px; border-radius: 10px; margin-bottom: 24px;">
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <label asp-for="Name"
                        style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase;">Full
                        Identity</label>
                    <input asp-for="Name"
                        style="padding: 14px 18px; border: 1px solid var(--border-color); border-radius: 12px; font-weight: 600; background: #f8fafc; outline: none; transition: var(--transition);"
                        placeholder="e.g. Alexander Pierce"
                        onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'" />
                    <span asp-validation-for="Name"
                        style="color: var(--danger); font-size: 11px; font-weight: 700;"></span>
                </div>

                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <label asp-for="Email"
                        style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase;">Email
                        Alias</label>
                    <input asp-for="Email" type="email"
                        style="padding: 14px 18px; border: 1px solid var(--border-color); border-radius: 12px; font-weight: 600; background: #f8fafc; outline: none; transition: var(--transition);"
                        placeholder="name@nexus.com"
                        onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'" />
                    <span asp-validation-for="Email"
                        style="color: var(--danger); font-size: 11px; font-weight: 700;"></span>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px;">
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <label asp-for="Password"
                        style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase;">Security
                        Key</label>
                    <input asp-for="Password" type="password"
                        style="padding: 14px 18px; border: 1px solid var(--border-color); border-radius: 12px; font-weight: 600; background: #f8fafc; outline: none; transition: var(--transition);"
                        onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'" />
                    <span asp-validation-for="Password"
                        style="color: var(--danger); font-size: 11px; font-weight: 700;"></span>
                </div>

                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <label asp-for="Role"
                        style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase;">Permission
                        Level</label>
                    <select asp-for="Role"
                        style="padding: 14px 18px; border: 1px solid var(--border-color); border-radius: 12px; font-weight: 700; background: #f8fafc; outline: none; cursor: pointer; color: var(--text-main);">
                        <option value="Student">Learner Access</option>
                        <option value="Instructor">Faculty Access</option>
                        <option value="Admin">System Administrator</option>
                    </select>
                    <span asp-validation-for="Role"
                        style="color: var(--danger); font-size: 11px; font-weight: 700;"></span>
                </div>
            </div>

            <div style="display: flex; gap: 16px;">
                <button type="submit"
                    style="flex: 2; background: var(--sidebar-active-bg); color: white; border: none; padding: 16px; border-radius: 14px; font-weight: 800; font-size: 15px; cursor: pointer; transition: var(--transition); box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);"
                    onmouseover="this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.transform='translateY(0)'">
                    Initialize Account
                </button>
                <a asp-action="ManageUsers"
                    style="flex: 1; text-align: center; text-decoration: none; background: white; border: 1px solid var(--border-color); color: var(--text-muted); padding: 16px; border-radius: 14px; font-weight: 800; font-size: 15px; transition: var(--transition);"
                    onmouseover="this.style.background='#f8fafc'; this.style.color='var(--text-main)'"
                    onmouseout="this.style.background='white'; this.style.color='var(--text-muted)'">
                    Abort
                </a>
            </div>
        </form>
    </div>
</div>

