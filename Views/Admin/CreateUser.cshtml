@model Project_BD.Models.User

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add New User";
}

<style>
    .cu-field { display: flex; flex-direction: column; gap: 8px; }
    .cu-label { font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.4px; }
    .cu-input {
        padding: 13px 16px; border: 2px solid var(--border-color);
        border-radius: 12px; font-size: 15px; font-weight: 600;
        background: #f8fafc; outline: none; transition: all .2s;
        color: var(--text-main); width: 100%;
    }
    .cu-input:focus { border-color: var(--primary); background: white; box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .cu-error { color: var(--danger); font-size: 12px; font-weight: 700; }
</style>

<div class="content-header animate-fade-in">
    <h1>Add New User</h1>
    <p>Create a new student, instructor, or admin account on the platform.</p>
</div>

<div style="display: flex; justify-content: center; margin-top: 32px;" class="animate-fade-in">
    <div class="card-section" style="width: 100%; max-width: 680px; padding: 40px;">

        @* Header *@
        <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid var(--border-color);">
            <div style="width: 52px; height: 52px; background: #eff6ff; color: var(--primary); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px;">
                <i class="fas fa-user-plus"></i>
            </div>
            <div>
                <h3 style="font-size: 19px; font-weight: 800; color: var(--text-main); margin: 0;">User Details</h3>
                <p style="font-size: 13px; color: var(--text-muted); margin: 4px 0 0;">Fill in the fields below to register a new user.</p>
            </div>
        </div>

        <form asp-action="CreateUser" method="post">
            @Html.AntiForgeryToken()

            @* Validation errors *@
            <div asp-validation-summary="ModelOnly"
                 style="color: var(--danger); font-size: 13px; font-weight: 700; background: #fef2f2; padding: 12px 16px; border-radius: 10px; margin-bottom: 24px; border-left: 3px solid var(--danger);">
            </div>

            @* Name + Email *@
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="cu-field">
                    <label asp-for="Name" class="cu-label">Full Name</label>
                    <input asp-for="Name" class="cu-input" placeholder="e.g. Rahul Sharma" />
                    <span asp-validation-for="Name" class="cu-error"></span>
                </div>
                <div class="cu-field">
                    <label asp-for="Email" class="cu-label">Email Address</label>
                    <input asp-for="Email" type="email" class="cu-input" placeholder="user@example.com" />
                    <span asp-validation-for="Email" class="cu-error"></span>
                </div>
            </div>

            @* Password + Role *@
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                <div class="cu-field">
                    <label asp-for="Password" class="cu-label">Password</label>
                    <input asp-for="Password" type="password" class="cu-input" placeholder="Set a strong password" />
                    <span asp-validation-for="Password" class="cu-error"></span>
                </div>
                <div class="cu-field">
                    <label asp-for="Role" class="cu-label">Role</label>
                    <select asp-for="Role" class="cu-input" style="cursor: pointer;">
                        <option value="Student">Student</option>
                        <option value="Instructor">Instructor</option>
                        <option value="Admin">Admin</option>
                    </select>
                    <span asp-validation-for="Role" class="cu-error"></span>
                </div>
            </div>

            @* Mobile + Gender *@
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px;">
                <div class="cu-field">
                    <label class="cu-label">Mobile (Optional)</label>
                    <input asp-for="Mobile" class="cu-input" placeholder="e.g. 9876543210" />
                </div>
                <div class="cu-field">
                    <label class="cu-label">Gender (Optional)</label>
                    <select asp-for="Gender" class="cu-input" style="cursor: pointer;">
                        <option value="">-- Select --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>

            @* Buttons *@
            <div style="display: flex; gap: 14px; padding-top: 24px; border-top: 1px solid var(--border-color);">
                <button type="submit"
                        style="flex: 2; background: var(--primary); color: white; border: none; padding: 15px; border-radius: 12px; font-weight: 800; font-size: 15px; cursor: pointer; transition: all .2s; display: flex; align-items: center; justify-content: center; gap: 10px; box-shadow: 0 4px 14px rgba(37,99,235,.25);"
                        onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(37,99,235,.35)'"
                        onmouseout="this.style.transform=''; this.style.boxShadow='0 4px 14px rgba(37,99,235,.25)'">
                    <i class="fas fa-user-plus"></i> Create User
                </button>
                <a asp-action="ManageUsers"
                   style="flex: 1; text-align: center; text-decoration: none; background: white; border: 2px solid var(--border-color); color: var(--text-muted); padding: 15px; border-radius: 12px; font-weight: 800; font-size: 15px; transition: all .2s; display: flex; align-items: center; justify-content: center; gap: 8px;"
                   onmouseover="this.style.borderColor='var(--primary)'; this.style.color='var(--primary)'"
                   onmouseout="this.style.borderColor='var(--border-color)'; this.style.color='var(--text-muted)'">
                    <i class="fas fa-arrow-left"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
