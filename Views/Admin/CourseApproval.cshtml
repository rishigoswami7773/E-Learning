@model IEnumerable<Project_BD.Models.Course>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Course Approval";
    string activeFilter = (ViewBag.Filter as string) ?? "pending";
    int pendingCount  = (int)(ViewBag.PendingCount  ?? 0);
    int approvedCount = (int)(ViewBag.ApprovedCount ?? 0);
}

<style>
    .ca-toast {
        position: fixed; top: 24px; right: 24px; z-index: 9999;
        color: white; padding: 16px 24px; border-radius: 14px;
        font-weight: 700; font-size: 15px;
        display: flex; align-items: center; gap: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
        animation: caSlideIn .4s ease;
    }
    @@keyframes caSlideIn { from { opacity:0; transform:translateX(60px); } to { opacity:1; transform:translateX(0); } }

    .ca-tabs { display:flex; gap:10px; }
    .ca-tab {
        padding: 10px 22px; border-radius: 10px; font-weight:700;
        font-size:14px; text-decoration:none; border:2px solid transparent;
        display:inline-flex; align-items:center; gap:8px; transition: all .2s;
    }
    .ca-tab.active { background:var(--primary); color:white; border-color:var(--primary); }
    .ca-tab:not(.active) { background:white; color:var(--text-muted); border-color:var(--border-color); }
    .ca-tab:not(.active):hover { border-color:var(--primary); color:var(--primary); }
    .ca-tab .tab-badge {
        background:rgba(0,0,0,0.15); padding:2px 8px;
        border-radius:20px; font-size:12px;
    }
    .ca-tab.active .tab-badge { background:rgba(255,255,255,0.25); }

    .ca-card {
        background:#fff; border:1px solid var(--border-color);
        border-radius:16px; box-shadow:0 2px 8px rgba(0,0,0,.05);
        margin-bottom:20px; overflow:hidden;
        display:grid; grid-template-columns:1fr auto;
    }
    .ca-card-body { display:flex; gap:24px; padding:24px; align-items:flex-start; }
    .ca-thumb {
        flex-shrink:0; width:180px; height:120px; border-radius:12px;
        overflow:hidden; border:1px solid var(--border-color);
        background:#f3f4f6; display:flex; align-items:center;
        justify-content:center; color:#9ca3af; font-size:28px;
    }
    .ca-thumb img { width:100%; height:100%; object-fit:cover; }
    .ca-info { flex:1; }
    .ca-title { font-size:18px; font-weight:800; color:var(--text-main); margin:0 0 8px; }
    .ca-meta { display:flex; gap:16px; font-size:13px; color:var(--text-muted); font-weight:600; margin-bottom:10px; flex-wrap:wrap; }
    .ca-desc { font-size:14px; color:var(--text-muted); line-height:1.7; margin:0; }
    .ca-actions {
        display:flex; flex-direction:column; gap:10px;
        padding:24px; min-width:170px; border-left:1px solid var(--border-color);
        background:#fafafa; justify-content:center;
    }
    .ca-btn {
        width:100%; border:none; cursor:pointer; padding:12px 16px;
        border-radius:10px; font-weight:700; font-size:14px;
        display:flex; align-items:center; justify-content:center;
        gap:8px; transition:all .2s;
    }
    .ca-btn-approve { background:#059669; color:white; }
    .ca-btn-approve:hover { background:#047857; transform:translateY(-1px); box-shadow:0 4px 12px rgba(5,150,105,.3); }
    .ca-btn-reject  { background:#fee2e2; color:#dc2626; }
    .ca-btn-reject:hover  { background:#fecaca; transform:translateY(-1px); }
    .ca-btn-preview { background:white; color:var(--text-main); border:2px solid var(--border-color); }
    .ca-btn-preview:hover { border-color:var(--primary); color:var(--primary); }
    .ca-empty {
        text-align:center; padding:80px 40px; background:white;
        border-radius:20px; border:2px dashed var(--border-color);
    }
    .ca-empty-icon {
        width:72px; height:72px; border-radius:50%;
        display:flex; align-items:center; justify-content:center;
        margin:0 auto 20px; font-size:28px;
    }
</style>

@* ── Toast ── *@
@if (TempData["ApprovalSuccess"] != null)
{
    <div class="ca-toast" style="background:#059669;">
        <i class="fas fa-circle-check" style="font-size:20px;"></i>
        <span>@TempData["ApprovalSuccess"]</span>
        <button onclick="this.parentElement.remove()" style="background:none;border:none;color:white;cursor:pointer;margin-left:8px;font-size:18px;">&times;</button>
    </div>
}
@if (TempData["ApprovalError"] != null)
{
    <div class="ca-toast" style="background:#dc2626;">
        <i class="fas fa-circle-xmark" style="font-size:20px;"></i>
        <span>@TempData["ApprovalError"]</span>
        <button onclick="this.parentElement.remove()" style="background:none;border:none;color:white;cursor:pointer;margin-left:8px;font-size:18px;">&times;</button>
    </div>
}

@* ── Header ── *@
<div class="content-header animate-fade-in">
    <h1>Course Approval Queue</h1>
    <p>Review and approve or reject submitted courses below.</p>
</div>

@* ── Stats ── *@
<div class="stats-grid animate-fade-in" style="animation-delay:.1s; margin-bottom:28px;">
    <div class="stat-card">
        <div>
            <div class="stat-label">Pending Review</div>
            <div class="stat-value">@pendingCount</div>
            <div class="stat-trend @(pendingCount > 0 ? "trend-down" : "trend-up")">
                @(pendingCount > 0 ? "Action Required" : "All Clear ✓")
            </div>
        </div>
        <div class="stat-icon-box" style="background:#fff7ed;color:#ea580c;">
            <i class="fas fa-clock-rotate-left"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Approved Courses</div>
            <div class="stat-value">@approvedCount</div>
            <div class="stat-trend trend-up">Live on platform</div>
        </div>
        <div class="stat-icon-box bg-green">
            <i class="fas fa-circle-check"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Review Capacity</div>
            <div class="stat-value">High</div>
            <div class="stat-trend trend-up">All systems go</div>
        </div>
        <div class="stat-icon-box bg-blue">
            <i class="fas fa-gauge-high"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Quality Score</div>
            <div class="stat-value">98%</div>
            <div class="stat-trend trend-up">Platform health</div>
        </div>
        <div class="stat-icon-box bg-indigo">
            <i class="fas fa-shield-heart"></i>
        </div>
    </div>
</div>

@* ── Filter Tabs ── *@
<div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:20px;">
    <h3 style="margin:0; font-weight:800; color:var(--text-main); font-size:18px;">
        @(activeFilter == "pending" ? "⏳ Pending Courses" : "✅ Approved Courses")
    </h3>
    <div class="ca-tabs">
        <a href="@Url.Action("CourseApproval", "Admin", new { filter = "pending" })"
           class="ca-tab @(activeFilter == "pending" ? "active" : "")">
            <i class="fas fa-clock"></i> Pending
            <span class="tab-badge">@pendingCount</span>
        </a>
        <a href="@Url.Action("CourseApproval", "Admin", new { filter = "approved" })"
           class="ca-tab @(activeFilter == "approved" ? "active" : "")">
            <i class="fas fa-check-circle"></i> Approved
            <span class="tab-badge">@approvedCount</span>
        </a>
    </div>
</div>

@* ── Course Cards ── *@
@if (Model != null && Model.Any())
{
    foreach (var course in Model)
    {
        <div class="ca-card animate-fade-in">
            <div class="ca-card-body">
                @* Thumbnail *@
                <div class="ca-thumb">
                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                    {
                        <img src="@course.ThumbnailUrl" alt="@course.Title" />
                    }
                    else
                    {
                        <i class="fas fa-graduation-cap"></i>
                    }
                </div>

                @* Info *@
                <div class="ca-info">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:8px; flex-wrap:wrap;">
                        <p class="ca-title">@course.Title</p>
                        @if (activeFilter == "pending")
                        {
                            <span class="badge badge-warning"><i class="fas fa-hourglass-half"></i> Awaiting Approval</span>
                        }
                        else
                        {
                            <span class="badge badge-success"><i class="fas fa-circle-check"></i> Approved</span>
                        }
                    </div>

                    <div class="ca-meta">
                        <span><i class="far fa-folder-open" style="color:var(--primary);"></i> @(course.Category?.Name ?? "General")</span>
                        <span><i class="fas fa-hashtag" style="color:var(--primary);"></i> Course #@course.CourseId</span>
                        <span><i class="fas fa-tag" style="color:var(--primary);"></i> ₹@course.Price</span>
                    </div>

                    <p class="ca-desc">
                        @(string.IsNullOrEmpty(course.Description)
                            ? "No description provided."
                            : (course.Description.Length > 220
                                ? course.Description.Substring(0, 220) + "…"
                                : course.Description))
                    </p>
                </div>
            </div>

            @* ── Action Buttons ── *@
            <div class="ca-actions">
                @* Preview link *@
                <a href="/Admin/Courses" class="ca-btn ca-btn-preview" style="text-decoration:none; text-align:center;">
                    <i class="far fa-eye"></i> View Course
                </a>

                @if (activeFilter == "pending")
                {
                    @* APPROVE *@
                    <form method="post" action="/Admin/ApproveCourse">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@course.CourseId" />
                        <button type="submit" class="ca-btn ca-btn-approve">
                            <i class="fas fa-check"></i> Approve
                        </button>
                    </form>

                    @* REJECT *@
                    <form method="post" action="/Admin/RejectCourse">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@course.CourseId" />
                        <button type="submit" class="ca-btn ca-btn-reject">
                            <i class="fas fa-trash-can"></i> Reject
                        </button>
                    </form>
                }
                else
                {
                    <div style="background:#ecfdf5; color:#059669; padding:12px 16px; border-radius:10px; font-weight:700; font-size:14px; text-align:center;">
                        <i class="fas fa-circle-check"></i> Live &amp; Active
                    </div>
                }
            </div>
        </div>
    }
}
else
{
    <div class="ca-empty">
        <div class="ca-empty-icon" style="background:@(activeFilter == "pending" ? "#ecfdf5" : "#eff6ff"); color:@(activeFilter == "pending" ? "#059669" : "#2563eb");">
            <i class="fas @(activeFilter == "pending" ? "fa-check-circle" : "fa-book-open")"></i>
        </div>
        @if (activeFilter == "pending")
        {
            <h3 style="font-size:22px; font-weight:800; margin-bottom:8px;">Queue is Empty!</h3>
            <p style="color:var(--text-muted); font-size:15px;">No courses are waiting for review. Great job!</p>
        }
        else
        {
            <h3 style="font-size:22px; font-weight:800; margin-bottom:8px;">No Approved Courses</h3>
            <p style="color:var(--text-muted); font-size:15px;">Approved courses will appear here.</p>
        }
    </div>
}

@* ── Guidelines ── *@
<div class="card-section animate-fade-in" style="margin-top:40px; animation-delay:.3s;">
    <h3 style="margin-bottom:20px; font-size:17px; font-weight:800; display:flex; align-items:center; gap:10px;">
        <i class="fas fa-circle-info" style="color:var(--primary);"></i> Review Guidelines
    </h3>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:40px;">
        <div>
            <h5 style="color:var(--success); margin-bottom:12px; font-weight:800; font-size:14px;">
                <i class="fas fa-circle-check"></i> Approve When
            </h5>
            <ul style="font-size:14px; color:var(--text-muted); line-height:2; padding-left:18px;">
                <li>Content is original and educational</li>
                <li>Clear learning objectives are defined</li>
                <li>Professional quality materials</li>
                <li>Accurate title and category</li>
            </ul>
        </div>
        <div>
            <h5 style="color:var(--danger); margin-bottom:12px; font-weight:800; font-size:14px;">
                <i class="fas fa-circle-xmark"></i> Reject When
            </h5>
            <ul style="font-size:14px; color:var(--text-muted); line-height:2; padding-left:18px;">
                <li>Plagiarized or copyrighted content</li>
                <li>Missing videos or broken links</li>
                <li>Poor quality or misleading title</li>
                <li>Violates platform standards</li>
            </ul>
        </div>
    </div>
</div>
