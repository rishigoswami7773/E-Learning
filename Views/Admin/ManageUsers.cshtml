@model IEnumerable<Project_BD.Models.User>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Users";
}

<div class="content-header animate-fade-in">
    <h1>Manage Users & Roles</h1>
    <p>View and manage all platform users, students, and instructors.</p>
</div>

<div class="stats-grid animate-fade-in" style="animation-delay: 0.1s;">
    <div class="stat-card">
        <div>
            <div class="stat-label">Total Users</div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-trend trend-up">Platform Wide</div>
        </div>
        <div class="stat-icon-box bg-blue">
            <i class="fas fa-users"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Students</div>
            <div class="stat-value">@Model.Count(u => u.Role == "Student")</div>
            <div class="stat-trend trend-up">Active Learners</div>
        </div>
        <div class="stat-icon-box bg-green">
            <i class="fas fa-user-graduate"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Instructors</div>
            <div class="stat-value">@Model.Count(u => u.Role == "Instructor")</div>
            <div class="stat-trend trend-up">Course Educators</div>
        </div>
        <div class="stat-icon-box bg-orange">
            <i class="fas fa-chalkboard-teacher"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">System Admins</div>
            <div class="stat-value">@Model.Count(u => u.Role == "Admin")</div>
            <div class="stat-trend trend-up">Moderation Team</div>
        </div>
        <div class="stat-icon-box bg-indigo">
            <i class="fas fa-user-shield"></i>
        </div>
    </div>
</div>

<div class="card-section animate-fade-in" style="animation-delay: 0.2s; padding: 0; overflow: hidden;">
    <div class="section-header" style="padding: 30px 30px 20px;">
        <h3>User Directory (@Model.Count())</h3>
        <div style="display: flex; gap: 16px;">
            <div style="position: relative;">
                <i class="fas fa-search"
                    style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 13px;"></i>
                <input type="text" placeholder="Search users..."
                    style="padding: 10px 16px 10px 40px; border: 1px solid var(--border-color); border-radius: 12px; font-size: 14px; width: 280px; background: #f8fafc; outline: none; transition: var(--transition);"
                    onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'" />
            </div>
            <a asp-controller="Admin" asp-action="CreateUser"
                style="background: var(--sidebar-active-bg); color: white; text-decoration: none; padding: 10px 20px; border-radius: 12px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 14px; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);">
                <i class="fas fa-plus"></i> Add User
            </a>
        </div>
    </div>

    <div style="overflow-x: auto;">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>User Identity</th>
                    <th>Role Group</th>
                    <th>Account Status</th>
                    <th>User ID</th>
                    <th style="text-align: right;">Operations</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="user-cell">
                                <div class="user-avatar"
                                    style="background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);">
                                    @((user.Name ?? "U").FirstOrDefault())
                                </div>
                                <div class="user-info">
                                    <span>@user.Name</span>
                                    <span>@user.Email</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge badge-admin"><i class="fas fa-crown" style="font-size: 10px;"></i>
                                    @user.Role</span>
                            }
                            else if (user.Role == "Instructor")
                            {
                                <span class="badge badge-instructor"><i class="fas fa-star" style="font-size: 10px;"></i>
                                    @user.Role</span>
                            }
                            else
                            {
                                <span class="badge badge-student"><i class="fas fa-graduation-cap" style="font-size: 10px;"></i>
                                    @user.Role</span>
                            }
                        </td>
                        <td>
                            <span class="badge badge-success">
                                <div style="width: 6px; height: 6px; background: currentColor; border-radius: 50%;"></div>
                                Active
                            </span>
                        </td>
                        <td style="color: var(--text-muted); font-weight: 700; font-family: monospace;">
                            #U-@user.UserId.ToString("D4")
                        </td>
                        <td style="text-align: right;">
                            <div style="display: flex; gap: 4px; justify-content: flex-end;">
                                <a asp-action="EditUser" asp-route-id="@user.UserId"
                                    style="width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 10px; color: var(--text-muted); transition: var(--transition);"
                                    onmouseover="this.style.background='#f1f5f9'; this.style.color='var(--primary)'"
                                    onmouseout="this.style.background='transparent'; this.style.color='var(--text-muted)'">
                                    <i class="fas fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteUser" asp-route-id="@user.UserId" method="post"
                                    onsubmit="return confirm('Are you sure you want to delete this user?');"
                                    style="display: inline; margin: 0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                        style="width: 36px; height: 36px; background: none; border: none; border-radius: 10px; color: var(--text-muted); cursor: pointer; transition: var(--transition); display: flex; align-items: center; justify-content: center;"
                                        onmouseover="this.style.background='#fee2e2'; this.style.color='var(--danger)'"
                                        onmouseout="this.style.background='transparent'; this.style.color='var(--text-muted)'">
                                        <i class="fas fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div
        style="padding: 20px 30px; background: #f8fafc; border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
        <div style="font-size: 13px; color: var(--text-muted); font-weight: 600;">
            Showing @Model.Count() total records
        </div>
        <div style="display: flex; gap: 8px;">
            <button
                style="padding: 8px 16px; border: 1px solid var(--border-color); border-radius: 10px; background: white; font-size: 13px; font-weight: 700; color: var(--text-muted); cursor: not-allowed;">Previous</button>
            <button
                style="padding: 8px 16px; border: 1px solid var(--border-color); border-radius: 10px; background: white; font-size: 13px; font-weight: 700; color: var(--text-muted); cursor: not-allowed;">Next</button>
        </div>
    </div>
</div>

