@using Project_BD.Models
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Analytics";
    var categoryStats = ViewBag.CategoryStats as IEnumerable<dynamic> ?? new List<dynamic>();
    var catLabels  = string.Join(",", categoryStats.Select(s => $"'{s.Category}'"));
    var catCounts  = string.Join(",", categoryStats.Select(s => (int)s.Count));
}

<style>
    .an-chart-wrap {
        position: relative; background: #fafbff;
        border-radius: 20px; border: 1px solid #f1f5f9;
        padding: 24px; margin-bottom: 24px;
    }
    .an-metric-row { display:flex; flex-direction:column; gap:14px; }
    .an-metric-item {
        display:flex; justify-content:space-between; align-items:center;
        padding: 10px 0; border-bottom: 1px solid var(--border-color);
    }
    .an-metric-item:last-child { border-bottom:none; }
    .an-bar-wrap {
        flex:1; margin: 0 16px; background:#f1f5f9;
        border-radius:999px; height:8px; overflow:hidden;
    }
    .an-bar-fill {
        height:100%; border-radius:999px; background:var(--primary);
        transition: width 1s ease;
    }
</style>

<div class="content-header animate-fade-in">
    <h1>Analytics</h1>
    <p>Data-driven insights into learner engagement, content performance, and system growth.</p>
</div>

@* ── Stats ── *@
<div class="stats-grid animate-fade-in" style="animation-delay:.1s; margin-bottom:28px;">
    <div class="stat-card">
        <div>
            <div class="stat-label">Active Learners</div>
            <div class="stat-value">@(ViewBag.ActiveLearners ?? 0)</div>
            <div class="stat-trend trend-up"><i class="fas fa-arrow-trend-up"></i> Enrolled Users</div>
        </div>
        <div class="stat-icon-box bg-blue"><i class="fas fa-users-viewfinder"></i></div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Quiz Pass Rate</div>
            <div class="stat-value">@Math.Round(ViewBag.CompletionRate ?? 0.0, 1)%</div>
            <div class="stat-trend trend-up"><i class="fas fa-medal"></i> Certification Rate</div>
        </div>
        <div class="stat-icon-box bg-green"><i class="fas fa-medal"></i></div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Total Users</div>
            <div class="stat-value">@(ViewBag.TotalUsers ?? 0)</div>
            <div class="stat-trend trend-up"><i class="fas fa-globe"></i> Registered Accounts</div>
        </div>
        <div class="stat-icon-box bg-orange"><i class="fas fa-chart-line"></i></div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Platform Uptime</div>
            <div class="stat-value">99.9%</div>
            <div class="stat-trend trend-up">Optimal SLA</div>
        </div>
        <div class="stat-icon-box bg-indigo"><i class="fas fa-server"></i></div>
    </div>
</div>

@* ── Charts Row ── *@
<div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:24px;">

    @* Bar Chart — Enrollments by Category *@
    <div class="card-section animate-fade-in" style="animation-delay:.2s; padding:28px;">
        <h3 style="margin-bottom:20px; font-size:17px; font-weight:800; color:var(--text-main);">
            <i class="fas fa-chart-bar" style="color:var(--primary); margin-right:8px;"></i>
            Enrollments by Category
        </h3>
        @if (categoryStats.Any())
        {
            <div class="an-chart-wrap" style="padding:16px; height:280px;">
                <canvas id="enrollChart"></canvas>
            </div>
        }
        else
        {
            <div style="height:280px; display:flex; align-items:center; justify-content:center; background:#fafbff; border-radius:16px; border:2px dashed var(--border-color); color:var(--text-muted); text-align:center;">
                <div>
                    <i class="fas fa-chart-column" style="font-size:36px; opacity:.3; margin-bottom:12px; display:block;"></i>
                    No enrollment data yet.
                </div>
            </div>
        }
    </div>

    @* Doughnut Chart — User Roles *@
    <div class="card-section animate-fade-in" style="animation-delay:.25s; padding:28px;">
        <h3 style="margin-bottom:20px; font-size:17px; font-weight:800; color:var(--text-main);">
            <i class="fas fa-chart-pie" style="color:#8b5cf6; margin-right:8px;"></i>
            User Role Distribution
        </h3>
        <div class="an-chart-wrap" style="padding:16px; height:280px; display:flex; align-items:center; justify-content:center;">
            <canvas id="roleChart" style="max-height:240px;"></canvas>
        </div>
    </div>
</div>

@* ── Category Breakdown Table ── *@
<div class="card-section animate-fade-in" style="animation-delay:.3s; padding:28px;">
    <h3 style="margin-bottom:24px; font-size:17px; font-weight:800; color:var(--text-main);">
        <i class="fas fa-table-list" style="color:var(--primary); margin-right:8px;"></i>
        Category Enrollment Breakdown
    </h3>

    @if (categoryStats.Any())
    {
        var maxCount = (int)categoryStats.Max(s => (int)s.Count);
        <div class="an-metric-row">
            @foreach (var stat in categoryStats)
            {
                var pct = maxCount > 0 ? (int)stat.Count * 100 / maxCount : 0;
                <div class="an-metric-item">
                    <span style="font-weight:700; color:var(--text-main); min-width:140px;">@stat.Category</span>
                    <div class="an-bar-wrap">
                        <div class="an-bar-fill" style="width:@(pct)%;"></div>
                    </div>
                    <span style="font-weight:800; color:var(--primary); min-width:80px; text-align:right;">
                        @stat.Count enrollments
                    </span>
                </div>
            }
        </div>
    }
    else
    {
        <p style="color:var(--text-muted); text-align:center; padding:32px 0;">No data available yet.</p>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// ── Bar Chart ──
@if (categoryStats.Any())
{
    <text>
    const ctx1 = document.getElementById('enrollChart').getContext('2d');
    new Chart(ctx1, {
        type: 'bar',
        data: {
            labels: [@Html.Raw(catLabels)],
            datasets: [{
                label: 'Enrollments',
                data: [@catCounts],
                backgroundColor: [
                    'rgba(37,99,235,.85)', 'rgba(16,185,129,.85)',
                    'rgba(245,158,11,.85)', 'rgba(139,92,246,.85)',
                    'rgba(239,68,68,.85)',  'rgba(20,184,166,.85)'
                ],
                borderRadius: 10, borderSkipped: false
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { stepSize: 1 } },
                x: { grid: { display: false } }
            }
        }
    });
    </text>
}

// ── Doughnut Chart — User Roles ──
const ctx2 = document.getElementById('roleChart').getContext('2d');
new Chart(ctx2, {
    type: 'doughnut',
    data: {
        labels: ['Students', 'Instructors', 'Admins'],
        datasets: [{
            data: [
                @(ViewBag.TotalUsers != null ? Math.Max(0, (int)ViewBag.TotalUsers - (int)(ViewBag.ActiveLearners ?? 0)) : 0),
                @(ViewBag.ActiveLearners ?? 0),
                1
            ],
            backgroundColor: ['rgba(37,99,235,.85)', 'rgba(16,185,129,.85)', 'rgba(139,92,246,.85)'],
            borderWidth: 0, hoverOffset: 6
        }]
    },
    options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
            legend: { position: 'bottom', labels: { padding: 20, font: { weight: '700' } } }
        },
        cutout: '65%'
    }
});
</script>
}
