@model Project_BD.Models.User

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Account Settings";
}

<div class="content-header animate-fade-in">
    <h1>Account Profile</h1>
    <p>Manage your administrative identity and security preferences.</p>
</div>

<div style="display: grid; grid-template-columns: 350px 1fr; gap: 32px; margin-top: 32px;" class="animate-fade-in"
    style="animation-delay: 0.1s;">
    <div class="card-section" style="text-align: center; height: fit-content; padding: 40px 30px;">
        <div style="position: relative; width: 140px; height: 140px; margin: 0 auto 24px;">
            <div
                style="width: 100%; height: 100%; background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 56px; font-weight: 800; box-shadow: 0 12px 24px rgba(99, 102, 241, 0.3); border: 4px solid white;">
                @((Model?.Name ?? "A").FirstOrDefault())
            </div>
            <div style="position: absolute; bottom: 5px; right: 5px; width: 36px; height: 36px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary); box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; transition: var(--transition);"
                onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                <i class="fas fa-camera"></i>
            </div>
        </div>

        <h3 style="font-size: 22px; font-weight: 800; color: var(--text-main); margin-bottom: 6px;">@(Model?.Name ??
            "Administrator")</h3>
        <p style="color: var(--text-muted); font-size: 14px; font-weight: 600; margin-bottom: 30px;">System
            @(Model?.Role ?? "Admin")</p>

        <div
            style="border-top: 1px solid var(--border-color); padding-top: 30px; display: flex; flex-direction: column; gap: 16px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 13px; color: var(--text-muted); font-weight: 700;">Identity Status</span>
                <span class="badge badge-success" style="font-size: 11px;">Verified</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 13px; color: var(--text-muted); font-weight: 700;">Joined Platform</span>
                <span style="font-size: 13px; color: var(--text-main); font-weight: 800;">Jan 24, 2024</span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span style="font-size: 13px; color: var(--text-muted); font-weight: 700;">Security Clearance</span>
                <span style="font-size: 13px; color: var(--primary); font-weight: 800;">Lvl 4 Admin</span>
            </div>
        </div>
    </div>

    <div class="card-section" style="padding: 40px;">
        <h3
            style="margin-bottom: 32px; font-size: 18px; font-weight: 800; color: var(--text-main); display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-id-card" style="color: var(--primary);"></i> Primary Credentials
        </h3>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <label
                    style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Display
                    Name</label>
                <input type="text" value="@Model.Name" readonly
                    style="width: 100%; padding: 14px 18px; border: 1px solid var(--border-color); border-radius: 12px; background: #f8fafc; color: var(--text-main); font-weight: 600; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <label
                    style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Communication
                    Hub</label>
                <input type="text" value="@Model.Email" readonly
                    style="width: 100%; padding: 14px 18px; border: 1px solid var(--border-color); border-radius: 12px; background: #f8fafc; color: var(--text-main); font-weight: 600; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <label
                    style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Permission
                    Group</label>
                <input type="text" value="@Model.Role" readonly
                    style="width: 100%; padding: 14px 18px; border: 1px solid var(--border-color); border-radius: 12px; background: #f8fafc; color: var(--text-main); font-weight: 600; outline: none;" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <label
                    style="font-size: 13px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Encryption
                    Status</label>
                <div
                    style="padding: 14px 18px; border: 1px solid #dcfce7; border-radius: 12px; background: #f0fdf4; color: var(--success); font-size: 14px; font-weight: 800; display: flex; align-items: center; gap: 12px;">
                    <i class="fas fa-shield-halved"></i> 256-bit AES Active
                </div>
            </div>
        </div>

        <div
            style="margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--border-color); display: flex; gap: 16px;">
            <button
                style="background: var(--sidebar-active-bg); color: white; border: none; padding: 14px 32px; border-radius: 14px; font-weight: 800; font-size: 14px; cursor: pointer; transition: var(--transition); box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);"
                onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                Save Account Changes
            </button>
            <button
                style="background: white; border: 1px solid var(--border-color); color: var(--text-main); padding: 14px 32px; border-radius: 14px; font-weight: 800; font-size: 14px; cursor: pointer; transition: var(--transition);"
                onmouseover="this.style.background='#f8fafc'; this.style.borderColor='var(--primary)'"
                onmouseout="this.style.background='white'; this.style.borderColor='var(--border-color)'">
                Reset Access Protocol
            </button>
        </div>
    </div>
</div>

