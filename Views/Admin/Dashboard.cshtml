    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">

    <!-- Stats -->
<div class="row g-3">

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6>Total Users</h6>
            <h3>@(ViewBag.TotalUsers ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6>Active Courses</h6>
            <h3>@(ViewBag.TotalCourses ?? 0)</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6>Total Revenue</h6>
            <h3>
                $@(ViewBag.TotalRevenue != null
                        ? ((decimal)ViewBag.TotalRevenue).ToString("N0")
                        : "0")
            </h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm p-3">
            <h6>Enrollments</h6>
            <h3>@(ViewBag.TotalEnrollments ?? 0)</h3>
        </div>
    </div>

</div>

<!-- Alerts -->
<div class="card mt-4 shadow-sm">
    <div class="card-header fw-bold">
        System Alerts
    </div>

    <div class="card-body d-flex justify-content-between flex-wrap">

        <div>
            ⚠ @(ViewBag.PendingCourses?.Count ?? 0) courses awaiting review
        </div>

        <div>
            📩 @(ViewBag.UnreadContactCount ?? 0) new inquiries
        </div>

    </div>
</div>

<!-- Main Grid -->
<div class="row mt-4">

    <!-- Pending Courses -->
    <div class="col-md-6">
        <div class="card shadow-sm">

            <div class="card-header d-flex justify-content-between">
                <span>Pending Approvals</span>
                <a asp-action="CourseApproval" class="btn btn-sm btn-primary">Manage</a>
            </div>

            <div class="card-body">

                @if (ViewBag.PendingCourses != null && ((IEnumerable<dynamic>)ViewBag.PendingCourses).Any())
                    {
                        foreach (var course in ViewBag.PendingCourses)
                        {
                <div class="d-flex justify-content-between align-items-center mb-3">

                    <div>
                        <strong>@course.Title</strong><br />
                        <small>@course.Category?.Name</small>
                    </div>

                    <div>
                        <form asp-action="ApproveCourse" asp-route-id="@course.CourseId" method="post">
                            <button class="btn btn-success btn-sm">✔</button>
                        </form>

                        <form asp-action="RejectCourse" asp-route-id="@course.CourseId" method="post">
                            <button class="btn btn-danger btn-sm">✖</button>
                        </form>
                    </div>

                </div>
                        }
                    }
                    else
                    {
                <p class="text-muted text-center">No pending courses</p>
                    }

            </div>

        </div>
    </div>

    <!-- Users -->
    <div class="col-md-6">
        <div class="card shadow-sm">

            <div class="card-header d-flex justify-content-between">
                <span>New Users</span>
                <a asp-action="ManageUsers" class="btn btn-sm btn-primary">View</a>
            </div>

            <div class="card-body">

                @if (ViewBag.RecentUsers != null && ((IEnumerable<dynamic>)ViewBag.RecentUsers).Any())
                    {
                        foreach (var user in ViewBag.RecentUsers)
                        {
                <div class="d-flex justify-content-between mb-2">

                    <div>
                        <strong>@user.Name</strong><br />
                        <small>@user.Role</small>
                    </div>

                    <span class="badge bg-info">@user.Role</span>

                </div>
                        }
                    }
                    else
                    {
                <p class="text-muted text-center">No users found</p>
                    }

            </div>

        </div>
    </div>

</div>

<!-- Quick Actions -->
<div class="mt-4">

    <h5>Quick Actions</h5>

    <div class="d-flex gap-3 flex-wrap mt-2">

        <a asp-action="Courses" class="btn btn-outline-primary">Courses</a>
        <a asp-action="ManageUsers" class="btn btn-outline-secondary">Users</a>
        <a asp-action="Analytics" class="btn btn-outline-success">Analytics</a>
        <a asp-action="Settings" class="btn btn-outline-dark">Settings</a>

    </div>

</div>

</div>
            </div>
        </div>
