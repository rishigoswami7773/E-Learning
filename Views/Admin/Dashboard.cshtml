@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

@* ── Toast Notification (from approve/reject actions) ── *@
@if (TempData["ApprovalSuccess"] != null)
{
    <div id="dash-toast" style="
        position: fixed; top: 24px; right: 24px; z-index: 9999;
        background: #059669; color: white;
        padding: 16px 24px; border-radius: 14px;
        font-weight: 700; font-size: 15px;
        box-shadow: 0 8px 32px rgba(5,150,105,0.35);
        display: flex; align-items: center; gap: 12px;
        animation: slideInToast 0.4s ease, fadeOutToast 0.5s ease 3.5s forwards;">
        <i class="fas fa-circle-check" style="font-size:20px;"></i>
        @TempData["ApprovalSuccess"]
    </div>
    <style>
        @@keyframes slideInToast { from { opacity:0; transform: translateX(60px); } to { opacity:1; transform:translateX(0); } }
        @@keyframes fadeOutToast  { from { opacity:1; } to { opacity:0; pointer-events:none; } }
    </style>
}

<style>
    .dash-stat-link {
        text-decoration: none; display: block;
        transition: transform .2s, box-shadow .2s;
        border-radius: 14px;
    }
    .dash-stat-link:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(0,0,0,.10);
    }
    .dash-stat-link .stat-card {
        cursor: pointer;
    }
</style>

<!-- Stats Grid -->
<div class="stats-grid animate-fade-in">
    <a class="dash-stat-link" asp-controller="Admin" asp-action="ManageUsers">
        <div class="stat-card" style="animation-delay: 0.1s;">
            <div class="stat-header">
                <div class="stat-icon-wrapper" style="background: #eff6ff; color: #3b82f6;">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-trend-tag tag-up" style="background: #e6fdf2; color: #059669;">+12.5%</div>
            </div>
            <div class="stat-label">Total Users</div>
            <div class="stat-value">@(ViewBag.TotalUsers ?? "0")</div>
            <div style="font-size:12px; color:var(--primary); font-weight:700; margin-top:6px;">View All Users →</div>
        </div>
    </a>

    <a class="dash-stat-link" asp-controller="Admin" asp-action="Courses">
        <div class="stat-card" style="animation-delay: 0.2s;">
            <div class="stat-header">
                <div class="stat-icon-wrapper" style="background: #f0fdf4; color: #10b981;">
                    <i class="fas fa-book-open"></i>
                </div>
                <div class="stat-trend-tag tag-up" style="background: #e6fdf2; color: #059669;">+8.2%</div>
            </div>
            <div class="stat-label">Active Courses</div>
            <div class="stat-value">@(ViewBag.TotalCourses ?? "0")</div>
            <div style="font-size:12px; color:#10b981; font-weight:700; margin-top:6px;">View All Courses →</div>
        </div>
    </a>

    <a class="dash-stat-link" asp-controller="Admin" asp-action="Payments">
        <div class="stat-card" style="animation-delay: 0.3s;">
            <div class="stat-header">
                <div class="stat-icon-wrapper" style="background: #fff7ed; color: #f59e0b;">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div class="stat-trend-tag tag-up" style="background: #e6fdf2; color: #059669;">+23.1%</div>
            </div>
            <div class="stat-label">REVENUE (EST)</div>
            <div class="stat-value">
                ₹@(ViewBag.TotalRevenue != null ? Convert.ToDecimal(ViewBag.TotalRevenue).ToString("N0") : "0")
            </div>
            <div style="font-size:12px; color:#f59e0b; font-weight:700; margin-top:6px;">View Payments →</div>
        </div>
    </a>

    <a class="dash-stat-link" asp-controller="Admin" asp-action="CourseApproval">
        <div class="stat-card" style="animation-delay: 0.4s;">
            <div class="stat-header">
                <div class="stat-icon-wrapper" style="background: #f5f3ff; color: #8b5cf6;">
                    <i class="fas fa-arrow-trend-up"></i>
                </div>
                <div class="stat-trend-tag tag-up" style="background: #e6fdf2; color: #059669;">+15.3%</div>
            </div>
            <div class="stat-label">PENDING COURSES</div>
            <div class="stat-value">
                @(ViewBag.PendingCourses is IEnumerable<dynamic> pc ? pc.Count() : 0)
            </div>
            <div style="font-size:12px; color:#8b5cf6; font-weight:700; margin-top:6px;">Review Pending →</div>
        </div>
    </a>
</div>

<!-- Main Sections -->
<div class="dashboard-grid animate-fade-in" style="animation-delay: 0.6s; display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 24px;">

    <!-- Approvals -->
    <div class="list-card">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; padding: 20px; border-bottom: 1px solid #f3f4f6;">
            <h3 style="margin: 0;">Pending Approvals</h3>
            <a asp-action="CourseApproval" class="btn-view-all" style="color: #3b82f6; text-decoration: none; font-size: 14px; font-weight: 600;">Manage All</a>
        </div>

        <div class="item-list">
            @if (ViewBag.PendingCourses is IEnumerable<dynamic> courses && courses.Any())
            {
                foreach (var course in courses)
                {
            <div class="list-item" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid #f3f4f6;">
                <div class="item-main" style="display: flex; align-items: center; gap: 16px;">

                    @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                            {
                    <img src="@course.ThumbnailUrl" style="width: 48px; height: 48px; border-radius: 12px; object-fit: cover; border: 1px solid #e5e7eb;" alt="@course.Title" />
                            }
                            else
                            {
                    <div class="item-icon" style="width: 48px; height: 48px; border-radius: 12px; background: #f3f4f6; display: flex; align-items: center; justify-content: center; color: #9ca3af;">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                            }

                    <div class="item-info">
                        <h4 style="margin: 0; font-size: 16px; font-weight: 600;">@course.Title</h4>
                        <p style="margin: 4px 0 0 0; font-size: 14px; color: #6b7280;">
                            @(course.Category != null ? course.Category.Name : "No Category") • Waiting for review
                        </p>
                    </div>
                </div>

                <div class="item-actions" style="display: flex; gap: 8px;">
                    <form asp-action="ApproveCourse" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@course.CourseId" />
                        <input type="hidden" name="returnUrl" value="/Admin/Dashboard" />
                        <button type="submit" class="btn-action" style="width: 36px; height: 36px; border-radius: 8px; border: none; background: #d1fae5; color: #059669; cursor: pointer;" title="Approve Course"
                                onclick="return confirm('Approve this course?')">
                            <i class="fas fa-check"></i>
                        </button>
                    </form>

                    <form asp-action="RejectCourse" method="post" style="margin:0;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@course.CourseId" />
                        <input type="hidden" name="returnUrl" value="/Admin/Dashboard" />
                        <button type="submit" class="btn-action" style="width: 36px; height: 36px; border-radius: 8px; border: none; background: #fee2e2; color: #dc2626; cursor: pointer;" title="Reject Course"
                                onclick="return confirm('Reject and remove this course permanently?')">
                            <i class="fas fa-xmark"></i>
                        </button>
                    </form>
                </div>
            </div>
                }
            }
            else
            {
            <div style="padding: 40px; text-align: center; color: #6b7280;">
                <p style="font-weight: 500; margin: 0; font-size: 14px;">No pending approvals</p>
            </div>
            }
        </div>
    </div>

    <!-- Registrations -->
    <div class="list-card">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; padding: 20px; border-bottom: 1px solid #f3f4f6;">
            <h3 style="margin: 0;">New Members</h3>
            <a asp-action="ManageUsers" class="btn-view-all" style="color: #3b82f6; text-decoration: none; font-size: 14px; font-weight: 600;">Directory</a>
        </div>

        <div class="item-list">
            @if (ViewBag.RecentUsers is IEnumerable<dynamic> users && users.Any())
            {
                foreach (var user in users)
                {
            <div class="list-item" style="display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid #f3f4f6;">
                <div class="item-main" style="display: flex; align-items: center; gap: 16px;">

                    <div class="item-icon" style="width: 48px; height: 48px; border-radius: 12px; background: #eff6ff; color: #3b82f6; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 18px;">
                        @(!string.IsNullOrEmpty(user.Name) ? user.Name.Substring(0,1).ToUpper() : "U")
                    </div>

                    <div class="item-info">
                        <h4 style="margin: 0; font-size: 16px; font-weight: 600;">@user.Name</h4>
                        <p style="margin: 4px 0 0 0; font-size: 14px; color: #6b7280;">@user.Role</p>
                    </div>
                </div>

                <div style="text-align: right;">
                    <span class="badge" style="padding: 6px 12px; border-radius: 4px; font-size: 11px; font-weight: 700; background: #f3f4f6; color: #374151;">
                        @user.Role
                    </span>
                </div>
            </div>
                }
            }
            else
            {
            <div style="padding: 40px; text-align: center; color: #9ca3af;">
                <p style="margin: 0;">No recent registrations.</p>
            </div>
            }
        </div>
    </div>

</div>







