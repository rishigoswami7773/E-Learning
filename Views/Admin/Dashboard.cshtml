@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    .dashboard-container {
        padding: 30px;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 25px;
        margin-bottom: 40px;
    }

    .stat-card {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .blue { background: #e0e7ff; color: #4338ca; }
    .green { background: #dcfce7; color: #15803d; }
    .orange { background: #ffedd5; color: #9a3412; }
    .purple { background: #f3e8ff; color: #7e22ce; }

    .stat-info h3 {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 5px;
    }

    .stat-info p {
        font-size: 24px;
        font-weight: bold;
        color: #111827;
    }

    .recent-activity {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .recent-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .recent-header h2 {
        font-size: 18px;
        color: #111827;
    }

    .activity-list {
        list-style: none;
    }

    .activity-item {
        display: flex;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .activity-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e5e7eb;
        margin-right: 15px;
    }

    .activity-details p {
        font-size: 14px;
        color: #111827;
    }

    .activity-details span {
        font-size: 12px;
        color: #6b7280;
    }
</style>

<div class="dashboard-container">
    <h1>Overview</h1>
    <p style="color: #6b7280; margin-bottom: 30px;">Welcome back, Admin! Here's what's happening today.</p>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon blue">👥</div>
            <div class="stat-info">
                <h3>Total Students</h3>
                <p>1,284</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">📚</div>
            <div class="stat-info">
                <h3>Active Courses</h3>
                <p>42</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange">💰</div>
            <div class="stat-info">
                <h3>Revenue</h3>
                <p>$12,450</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon purple">🎓</div>
            <div class="stat-info">
                <h3>Certificates</h3>
                <p>156</p>
            </div>
        </div>
    </div>

    <div class="recent-activity">
        <div class="recent-header">
            <h2>Recent Enrolments</h2>
            <a href="#" style="color: #2b59ff; text-decoration: none; font-size: 14px;">View All</a>
        </div>
        <ul class="activity-list">
            <li class="activity-item">
                <div class="activity-img"></div>
                <div class="activity-details">
                    <p><strong>John Doe</strong> enrolled in <strong>Full Stack Web Dev</strong></p>
                    <span>2 minutes ago</span>
                </div>
            </li>
            <li class="activity-item">
                <div class="activity-img"></div>
                <div class="activity-details">
                    <p><strong>Jane Smith</strong> enrolled in <strong>Advanced React Patterns</strong></p>
                    <span>1 hour ago</span>
                </div>
            </li>
            <li class="activity-item">
                <div class="activity-img"></div>
                <div class="activity-details">
                    <p><strong>Mike Ross</strong> enrolled in <strong>Python for Data Science</strong></p>
                    <span>3 hours ago</span>
                </div>
            </li>
        </ul>
    </div>
</div>
