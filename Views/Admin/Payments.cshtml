@model IEnumerable<Project_BD.Models.Enrollment>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Financial Portal";
}

<div class="content-header animate-fade-in">
    <h1>Financial Portal</h1>
    <p>Comprehensive transaction monitoring and platform revenue analytics.</p>
</div>

<div class="stats-grid animate-fade-in" style="animation-delay: 0.1s;">
    <div class="stat-card">
        <div>
            <div class="stat-label">Lifetime Revenue</div>
            <div class="stat-value">₹@ViewBag.TotalRevenue.ToString("N0")</div>
            <div class="stat-trend trend-up"><i class="fas fa-chart-line"></i> Analytics Based</div>
        </div>
        <div class="stat-icon-box bg-green">
            <i class="fas fa-money-bill-trend-up"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Total Transactions</div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-trend trend-up">Validated Purchases</div>
        </div>
        <div class="stat-icon-box bg-blue">
            <i class="fas fa-arrows-rotate"></i>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Platform Health</div>
            <div class="stat-value">100%</div>
            <div class="stat-trend trend-up">Gateway Operational</div>
        </div>
        <div class="stat-icon-box bg-indigo">
            <i class="fas fa-circle-check"></i>
        </div>
    </div>
</div>

<div class="card-section animate-fade-in" style="animation-delay: 0.2s; padding: 0; overflow: hidden;">
    <div class="section-header" style="padding: 30px 30px 20px;">
        <h3>Transaction Ledger</h3>
    </div>

    <div style="overflow-x: auto;">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Hash ID</th>
                    <th>Account Holder</th>
                    <th>Asset Details</th>
                    <th>Net Amount</th>
                    <th>Authorization</th>
                    <th style="text-align: right;">Time Stamp</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var enrollment in Model)
                    {
                        <tr>
                            <td>
                                <span style="font-family: monospace; font-weight: 800; color: var(--primary); background: #f5f3ff; padding: 4px 8px; border-radius: 6px;">
                                    TX-@enrollment.EnrollmentId.ToString("D6")
                                </span>
                            </td>
                            <td>
                                <div style="font-weight: 700; color: var(--text-main);">@(enrollment.User?.Name ?? "External")</div>
                                <div style="font-size: 12px; color: var(--text-muted);">@(enrollment.User?.Email ?? "N/A")</div>
                            </td>
                            <td style="font-weight: 600;">@(enrollment.Course?.Title ?? "System Asset")</td>
                            <td style="font-weight: 800; color: var(--text-main);">₹@(enrollment.Course?.Price ?? 0)</td>
                            <td><span class="badge badge-success"><i class="fas fa-shield-check"></i> Verified</span></td>
                            <td style="text-align: right; color: var(--text-muted); font-size: 13px;">
                                @enrollment.EnrollmentDate.ToString("MMM dd, yyyy • HH:mm")
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">
                            No transactions detected in the system logs.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div
        style="padding: 24px 30px; background: #fcfdfe; border-top: 1px solid var(--border-color); color: var(--text-muted); font-size: 13px; font-weight: 600;">
        <i class="fas fa-lock" style="margin-right: 8px;"></i> All transaction data is encrypted and compliant with
        financial regulations.
    </div>
</div>

