@model IEnumerable<Project_BD.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<style>
    .categories-container {
        padding: 40px 8%;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .header-section h1 {
        font-size: 32px;
        color: #1f2937;
    }

    .btn-create {
        background: #2b59ff;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-create:hover {
        background: #1e40af;
    }

    .table-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #f9fafb;
        text-align: left;
        padding: 15px 20px;
        font-size: 14px;
        font-weight: 600;
        color: #4b5563;
        border-bottom: 1px solid #f3f4f6;
    }

    td {
        padding: 15px 20px;
        font-size: 14px;
        color: #111827;
        border-bottom: 1px solid #f3f4f6;
    }

    tr:last-child td {
        border-bottom: none;
    }

    .actions {
        display: flex;
        gap: 15px;
    }

    .btn-edit {
        color: #2b59ff;
        text-decoration: none;
        font-weight: 500;
    }

    .btn-delete {
        color: #ef4444;
        text-decoration: none;
        font-weight: 500;
    }
</style>

<div class="categories-container">
    <div class="header-section">
        <h1>Categories</h1>
        <a asp-action="Create" class="btn-create">+ Add New Category</a>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Category Name</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td class="actions">
                            <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn-edit">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn-delete">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
