@model Project_BD.Models.Course

@{
    ViewData["Title"] = Model.Title;
}

<style>
    .course-details-container {
        padding: 40px 8%;
        max-width: 1200px;
        margin: 0 auto;
    }

    .course-hero {
        background: white;
        padding: 40px;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        display: flex;
        gap: 40px;
        margin-bottom: 40px;
    }

    .course-hero-img {
        width: 300px;
        height: 200px;
        background: #2b59ff;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 60px;
        color: white;
    }

    .course-hero-content {
        flex: 1;
    }

    .course-hero-content h1 {
        font-size: 36px;
        color: #111827;
        margin-bottom: 15px;
    }

    .category-badge {
        display: inline-block;
        padding: 5px 12px;
        background: #e0e7ff;
        color: #4338ca;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .course-price-large {
        font-size: 28px;
        color: #2b59ff;
        font-weight: bold;
        margin: 20px 0;
    }

    .btn-enroll {
        padding: 12px 30px;
        background: #2b59ff;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        font-size: 16px;
    }

    .course-main-content {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 40px;
    }

    .syllabus-section h2 {
        font-size: 24px;
        margin-bottom: 25px;
    }

    .module-card {
        background: white;
        border-radius: 12px;
        margin-bottom: 15px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
    }

    .module-header {
        padding: 15px 20px;
        background: #f9fafb;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
    }

    .module-header h3 {
        font-size: 16px;
        color: #111827;
    }

    .lesson-list {
        background: white;
        border-top: 1px solid #e5e7eb;
    }

    .lesson-item {
        padding: 12px 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 14px;
        color: #4b5563;
        border-bottom: 1px solid #f3f4f6;
    }

    .lesson-item:last-child {
        border-bottom: none;
    }

    .lesson-icon {
        color: #2b59ff;
    }

    .rating-overview {
        margin: 18px 0;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .star {
        color: #f59e0b;
        font-size: 16px;
    }

    .review-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px;
        margin-top: 12px;
    }
</style>

<div class="course-details-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: #dcfce7; color: #166534; padding: 12px 16px; border-radius: 10px; margin-bottom: 16px; font-weight: 600;">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ReviewError"] != null)
    {
        <div style="background: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 10px; margin-bottom: 16px; font-weight: 600;">
            @TempData["ReviewError"]
        </div>
    }
    @if (TempData["ReviewSuccess"] != null)
    {
        <div style="background: #dcfce7; color: #166534; padding: 12px 16px; border-radius: 10px; margin-bottom: 16px; font-weight: 600;">
            @TempData["ReviewSuccess"]
        </div>
    }
    @if (TempData["QuizError"] != null)
    {
        <div style="background: #fef3c7; color: #92400e; padding: 12px 16px; border-radius: 10px; margin-bottom: 16px; font-weight: 600;">
            @TempData["QuizError"]
        </div>
    }

    <div class="course-hero">
        <div class="course-hero-img">
            @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
            {
                <img src="@Model.ThumbnailUrl" alt="@Model.Title"
                    style="width: 100%; height: 100%; object-fit: cover; border-radius: 12px;" />
            }
            else
            {
                <span>📘</span>
            }
        </div>
        <div class="course-hero-content">
            <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 20px;">
                <span class="category-badge" style="margin-bottom: 0;">@(Model.Category?.Name ?? "General")</span>
                @if (ViewBag.UserRole == "Admin")
                {
                    <span class="category-badge" style="background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; margin-bottom: 0;">
                        <i class="fas fa-shield-halved"></i> Admin Privileged Access
                    </span>
                }
            </div>
            <h1>@Model.Title</h1>
            <p style="color: #4b5563; font-size: 18px;">@Model.Description</p>
            <div class="rating-overview">
                <div>
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round((double)ViewBag.AverageRating))
                        {
                            <span class="star">★</span>
                        }
                        else
                        {
                            <span class="star" style="color:#d1d5db;">★</span>
                        }
                    }
                </div>
                <strong>@string.Format("{0:0.0}", (double)ViewBag.AverageRating)/5</strong>
                <span style="color:#6b7280;">(@ViewBag.TotalReviews reviews)</span>
            </div>
            @if (ViewBag.IsEnrolled)
            {
                <div style="display: flex; gap: 10px; align-items: center; margin-top: 20px;">
                    <span
                        style="color: #059669; font-weight: bold; background: #d1fae5; padding: 10px 20px; border-radius: 8px;">✓
                        @(ViewBag.UserRole == "Admin" ? "Full Access Granted" : "Enrolled")</span>
                    @if (Model.Quizzes != null && Model.Quizzes.Any())
                    {
                        <a asp-controller="Quiz" asp-action="TakeQuiz" asp-route-id="@Model.Quizzes.First().QuizId"
                            class="btn-enroll" style="background: #059669; text-decoration: none;">Take Course Quiz</a>
                    }
                </div>
            }
            else
            {
                <a asp-action="Payment" asp-route-id="@Model.CourseId" class="btn-enroll" style="display:inline-block; text-decoration:none; margin-top:20px;">
                    Proceed to Payment & Enroll
                </a>
            }
        </div>
    </div>

    <div class="course-main-content">
        <div class="syllabus-section">
            <h2>Course Syllabus</h2>

            @if (Model.Modules != null && Model.Modules.Any())
            {
                foreach (var module in Model.Modules)
                {
                    <div class="module-card">
                        <div class="module-header">
                            <h3>@module.ModuleTitle</h3>
                            <span style="color: #6b7280; font-size: 12px;">@(module.Lessons?.Count ?? 0) Lessons</span>
                        </div>
                        <div class="lesson-list">
                            @if (module.Lessons != null && module.Lessons.Any())
                            {
                                foreach (var lesson in module.Lessons)
                                {
                                    <div class="lesson-item">
                                        <span class="lesson-icon">@(ViewBag.IsEnrolled ? "▶" : "🔒")</span>
                                        @if (ViewBag.IsEnrolled)
                                        {
                                            <a asp-action="WatchLesson" asp-route-id="@lesson.LessonId"
                                                style="text-decoration: none; color: inherit;">@lesson.LessonTitle</a>
                                            <a asp-action="WatchLesson" asp-route-id="@lesson.LessonId"
                                                style="margin-left: auto; font-size: 12px; color: #2b59ff; text-decoration: none;">Watch</a>
                                        }
                                        else
                                        {
                                            <span style="color: #9ca3af;">@lesson.LessonTitle</span>
                                            <span style="margin-left: auto; font-size: 12px; color: #9ca3af;">Locked</span>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="lesson-item">No lessons in this module.</div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <p>No syllabus available yet.</p>
            }
        </div>

        <div class="sidebar-section">
            <div
                style="background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                <h3 style="margin-bottom: 20px; font-size: 18px;">Course Info</h3>
                <ul style="list-style: none; color: #4b5563; font-size: 14px; margin-bottom: 20px;">
                    <li style="margin-bottom: 10px;">🕒 Full lifetime access</li>
                    <li style="margin-bottom: 10px;">📱 Access on mobile and TV</li>
                    <li style="margin-bottom: 10px;">📜 Certificate of completion</li>
                </ul>

                @if (ViewBag.IsEnrolled)
                {
                    if (Model.Quizzes != null && Model.Quizzes.Any())
                    {
                        <a asp-controller="Quiz" asp-action="TakeQuiz" asp-route-id="@Model.Quizzes.First().QuizId"
                            class="btn-enroll"
                            style="display: block; text-align: center; text-decoration: none; background: #059669;">Take Final Quiz</a>
                    }
                    else
                    {
                        <button class="btn-enroll"
                            style="display: block; width: 100%; background: #9ca3af; cursor: not-allowed;" disabled>No Quiz Available</button>
                    }
                }
                else
                {
                    <p style="font-size: 14px; text-align: center; color: #6b7280; border-top: 1px solid #eee; pt-3; mt-3;">Enroll to access course content and quizzes.</p>
                }
            </div>

            <div style="background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-top: 16px;">
                <h3 style="margin-bottom: 16px; font-size: 18px;">Rate This Course</h3>
                @if (ViewBag.IsEnrolled == true && ViewBag.UserRole != "Admin")
                {
                    <form asp-controller="Review" asp-action="AddOrUpdate" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="courseId" value="@Model.CourseId" />
                        <label style="display:block; margin-bottom:8px; font-weight:600;">Rating</label>
                        <select name="rating" style="width:100%; padding:10px; border:1px solid #d1d5db; border-radius:8px; margin-bottom:12px;">
                            @for (int i = 5; i >= 1; i--)
                            {
                                if (ViewBag.MyReview != null && ViewBag.MyReview.Rating == i)
                                {
                                    <option value="@i" selected>@i Star</option>
                                }
                                else
                                {
                                    <option value="@i">@i Star</option>
                                }
                            }
                        </select>
                        <label style="display:block; margin-bottom:8px; font-weight:600;">Comment</label>
                        <textarea name="comment" rows="4" required style="width:100%; padding:10px; border:1px solid #d1d5db; border-radius:8px;">@(ViewBag.MyReview?.Comment ?? "")</textarea>
                        <button type="submit" class="btn-enroll" style="margin-top:12px; width:100%;">Save Review</button>
                    </form>
                }
                else
                {
                    <p style="color:#6b7280; margin:0;">Enroll first to submit your rating and review.</p>
                }
            </div>
        </div>
    </div>

    <div style="margin-top: 28px;">
        <h2 style="font-size: 24px; margin-bottom: 14px;">Student Reviews</h2>
        @if (ViewBag.Reviews != null && ViewBag.Reviews.Count > 0)
        {
            @foreach (var review in ViewBag.Reviews)
            {
                <div class="review-card">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <strong>@(review.User?.Name ?? "Student")</strong>
                        <span>
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= review.Rating)
                                {
                                    <span class="star">★</span>
                                }
                                else
                                {
                                    <span class="star" style="color:#d1d5db;">★</span>
                                }
                            }
                        </span>
                    </div>
                    <p style="margin:8px 0 0; color:#4b5563;">@review.Comment</p>
                </div>
            }
        }
        else
        {
            <p style="color:#6b7280;">No reviews yet. Be the first to review this course.</p>
        }
    </div>
</div>
