@model IEnumerable<Project_BD.Models.Course>

@{
    ViewData["Title"] = "Professional Catalog";
}

<style>
    .catalog-header {
        padding: 80px 8% 40px;
        text-align: center;
        background: white;
    }

    .catalog-header span {
        font-size: 14px;
        text-transform: uppercase;
        color: var(--primary);
        font-weight: 800;
        letter-spacing: 2px;
    }

    .catalog-header h1 {
        font-size: 48px;
        font-weight: 800;
        color: var(--text-main);
        letter-spacing: -2px;
        margin: 12px 0 24px;
    }

    .filter-bar {
        background: white;
        margin: 0 8% 60px;
        padding: 32px;
        border-radius: 24px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border);
        display: grid;
        grid-template-columns: 1.5fr 2fr;
        gap: 40px;
        align-items: center;
    }

    @media(max-width:992px) {
        .filter-bar {
            grid-template-columns: 1fr;
        }
    }

    .search-wrapper {
        position: relative;
    }

    .search-wrapper i {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
    }

    .search-input {
        width: 100%;
        padding: 16px 20px 16px 52px;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: #f8fafc;
        outline: none;
        font-weight: 600;
        transition: all 0.3s;
    }

    .search-input:focus {
        border-color: var(--primary);
        background: white;
        box-shadow: 0 0 0 4px var(--primary-light);
    }

    .price-range-wrapper {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .range-labels {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: 800;
        color: var(--text-muted);
        text-transform: uppercase;
    }

    .price-slider {
        width: 100%;
        height: 6px;
        background: #e2e8f0;
        border-radius: 10px;
        appearance: none;
        outline: none;
    }

    .price-slider::-webkit-slider-thumb {
        appearance: none;
        width: 20px;
        height: 20px;
        background: var(--primary);
        border: 4px solid white;
        border-radius: 50%;
        cursor: pointer;
        box-shadow: var(--shadow);
    }

    .tabs-container {
        margin: 0 8% 40px;
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 10px;
    }

    .category-tab {
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        font-size: 14px;
        white-space: nowrap;
        transition: all 0.2s;
        border: 1px solid var(--border);
        background: white;
        color: var(--text-muted);
    }

    .category-tab:hover {
        border-color: var(--primary);
        color: var(--primary);
    }

    .category-tab.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
        box-shadow: 0 8px 16px -4px rgba(37, 99, 235, 0.4);
    }

    /* Course Cards (Photo Style) */
    .catalog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 32px;
        padding: 0 8% 100px;
    }

    .premium-course-card {
        background: #0f172a;
        border-radius: 40px;
        overflow: hidden;
        position: relative;
        height: 480px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
    }

    .premium-course-card:hover {
        transform: translateY(-12px) scale(1.02);
        box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.3);
    }

    .course-bg-img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6;
        transition: transform 0.6s;
    }

    .premium-course-card:hover .course-bg-img {
        transform: scale(1.1);
    }

    .card-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 20%, rgba(15, 23, 42, 0.9) 80%);
        padding: 40px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .instructor-tag {
        position: absolute;
        top: 30px;
        right: 30px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        padding: 8px 16px;
        border-radius: 100px;
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .instructor-tag img {
        width: 24px;
        height: 24px;
        border-radius: 50%;
    }

    .instructor-tag span {
        color: white;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .cat-pill {
        background: var(--primary);
        color: white;
        padding: 6px 16px;
        border-radius: 8px;
        font-size: 11px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        align-self: flex-start;
        margin-bottom: 16px;
    }

    .card-title {
        color: white;
        font-size: 28px;
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: -1px;
        margin-bottom: 16px;
    }

    .card-description {
        color: #94a3b8;
        font-size: 15px;
        line-height: 1.5;
        margin-bottom: 30px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 24px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .price-group {
        display: flex;
        flex-direction: column;
    }

    .price-label {
        color: #64748b;
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
    }

    .price-val {
        color: #10b981;
        font-size: 24px;
        font-weight: 800;
    }

    .btn-explore {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 14px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        transition: all 0.3s;
    }

    .premium-course-card:hover .btn-explore {
        background: white;
        color: var(--text-main);
    }
</style>

<div class="catalog-header">
    <span>Catalog</span>
    <h1>Master New Skills</h1>
    <p style="color: var(--text-muted); max-width: 600px; margin: 0 auto;">Join 15,000+ students learning the most
        in-demand technologies today.</p>
</div>

<div class="filter-bar">
    <div class="search-wrapper">
        <i class="fas fa-search"></i>
        <input type="text" class="search-input" placeholder="Search courses..." id="courseSearch" />
    </div>

    <div class="price-range-wrapper">
        <div class="range-labels">
            <span>Min Price</span>
            <span id="priceDisplay">Max Price: $20,000</span>
        </div>
        <input type="range" class="price-slider" min="0" max="20000" step="100" value="20000" id="priceRange" />
    </div>
</div>

<div class="tabs-container">
    <a asp-action="Index" class="category-tab @(ViewBag.SelectedCategoryId == null ? "active" : "")">All Courses</a>
    @if (ViewBag.Categories != null)
    {
        foreach (var cat in ViewBag.Categories)
        {
            <a asp-action="Index" asp-route-categoryId="@cat.CategoryId"
                class="category-tab @(ViewBag.SelectedCategoryId == cat.CategoryId ? "active" : "")">
                @cat.Name
            </a>
        }
    }
</div>

<div class="catalog-grid">
    @if (!Model.Any())
    {
        <div
            style="grid-column: 1/-1; text-align: center; padding: 100px; background: white; border-radius: 40px; border: 1px dashed var(--border);">
            <i class="fas fa-search" style="font-size: 48px; color: var(--border); margin-bottom: 24px;"></i>
            <h3 style="font-size: 24px; font-weight: 800;">No courses found</h3>
            <p style="color: var(--text-muted);">Try adjusting your filters or category.</p>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            <a asp-action="Details" asp-route-id="@item.CourseId" class="premium-course-card">
                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                {
                    <img src="@item.ThumbnailUrl" class="course-bg-img" alt="@item.Title" />
                }
                else
                {
                    <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&q=80&w=2070"
                        class="course-bg-img" alt="Course" />
                }

                <div class="instructor-tag">
                    <img src="https://i.pravatar.cc/150?u=@(item.CourseId)" />
                    <span>@(item.InstructorName ?? "Industry Expert")</span>
                </div>

                <div class="card-overlay">
                    <div class="cat-pill">@(item.Category?.Name ?? "General")</div>
                    <h3 class="card-title">@item.Title</h3>
                    <p class="card-description">@item.Description</p>

                    <div class="card-footer">
                        <div class="price-group">
                            <span class="price-label">Fixed Price</span>
                            <span class="price-val">$@item.Price</span>
                        </div>
                        <div class="btn-explore">Explore Course</div>
                    </div>
                </div>

                @if (Context.Session.GetString("UserRole") == "Admin" && !item.IsApproved)
                {
                    <div
                        style="position: absolute; top: 30px; left: 30px; background: #ef4444; color: white; padding: 4px 12px; border-radius: 8px; font-size: 10px; font-weight: 900;">
                        PENDING</div>
                }
            </a>
        }
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#priceRange').on('input', function () {
                $('#priceDisplay').text('Max Price: $' + $(this).val());
                filterCourses();
            });

            $('#courseSearch').on('keyup', function () {
                filterCourses();
            });

            function filterCourses() {
                const query = $('#courseSearch').val().toLowerCase();
                const maxPrice = parseInt($('#priceRange').val());

                $('.premium-course-card').each(function () {
                    const title = $(this).find('.card-title').text().toLowerCase();
                    const price = parseInt($(this).find('.price-val').text().replace('$', ''));

                    if (title.includes(query) && price <= maxPrice) {
                        $(this).fadeIn();
                    } else {
                        $(this).fadeOut();
                    }
                });
            }
        });
    </script>
}