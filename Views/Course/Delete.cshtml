@model Project_BD.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<style>
    .delete-container {
        max-width: 500px;
        margin: 80px auto;
        padding: 40px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        text-align: center;
    }

    .warning-icon {
        font-size: 60px;
        color: #ef4444;
        margin-bottom: 20px;
    }

    .delete-header h2 {
        font-size: 24px;
        color: #111827;
        margin-bottom: 10px;
    }

    .delete-header p {
        color: #6b7280;
        margin-bottom: 30px;
    }

    .course-summary {
        background: #fef2f2;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
        text-align: left;
    }

    .course-summary dl {
        margin: 0;
    }

    .course-summary dt {
        font-size: 12px;
        color: #991b1b;
        text-transform: uppercase;
        font-weight: bold;
    }

    .course-summary dd {
        font-size: 16px;
        color: #111827;
        margin-bottom: 15px;
        font-weight: 500;
    }

    .course-summary dd:last-child {
        margin-bottom: 0;
    }

    .btn-delete {
        width: 100%;
        padding: 12px;
        background: #ef4444;
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        margin-bottom: 15px;
    }

    .btn-delete:hover {
        background: #dc2626;
    }

    .btn-cancel {
        display: block;
        color: #6b7280;
        text-decoration: none;
        font-size: 14px;
    }
</style>

<div class="delete-container">
    <div class="warning-icon">⚠️</div>
    <div class="delete-header">
        <h2>Delete Course?</h2>
        <p>This action cannot be undone. All data related to this course will be permanently removed.</p>
    </div>

    <div class="course-summary">
        <dl>
            <dt>Course Title</dt>
            <dd>@Model.Title</dd>
            
            <dt>Category</dt>
            <dd>@Model.Category?.Name</dd>

            <dt>Price</dt>
            <dd>$@Model.Price</dd>
        </dl>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="CourseId" />
        <button type="submit" class="btn-delete">Yes, Delete Course</button>
    </form>
    <a asp-action="Index" class="btn-cancel">No, keep it</a>
</div>
