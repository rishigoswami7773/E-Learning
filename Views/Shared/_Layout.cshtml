<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-Learning</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: #f5f7fa;
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 8%;
            background: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .logo {
            font-weight: bold;
            font-size: 20px;
        }

        .nav-links {
            list-style: none;
            display: flex;
            gap: 25px;
        }

        .nav-links a {
            text-decoration: none;
            color: #333;
            font-weight: 500;
        }

        .profile-btn {
            padding: 8px 15px;
            background: #f1f1f1;
            border-radius: 6px;
        }

        /* Hero */
        .hero {
            text-align: center;
            padding: 80px 20px;
            background: linear-gradient(135deg, #2b59ff, #4e73df);
            color: white;
        }

        .hero h1 {
            font-size: 42px;
            margin-bottom: 15px;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 30px;
        }

        .btn-primary {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            background: white;
            color: #2b59ff;
            font-weight: bold;
            cursor: pointer;
            margin: 10px;
        }

        .btn-secondary {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            background: #dfe6ff;
            color: #2b59ff;
            font-weight: bold;
            cursor: pointer;
            margin: 10px;
        }

        /* Features */
        .features {
            padding: 70px 8%;
            text-align: center;
        }

        .features h2 {
            font-size: 30px;
            margin-bottom: 10px;
        }

        .subtitle {
            color: gray;
            margin-bottom: 40px;
        }

        .feature-cards {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            width: 300px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }

        .icon {
            font-size: 35px;
            margin-bottom: 15px;
        }

        /* CTA */
        .cta {
            text-align: center;
            padding: 60px 20px;
            background: #e9eef6;
        }

        .btn-dark {
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            background: #111827;
            color: white;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 20px;
            background: #1f2937;
            color: white;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="logo">🎓 E-Learning</div>
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Course" asp-action="Index">Courses</a></li>
            <li><a asp-controller="Admin" asp-action="Dashboard">Admin Panel</a></li>
            <li><a href="#" class="profile-btn">Profile</a></li>
        </ul>
    </nav>

    @RenderBody()

    <!-- Footer -->
    <footer>
        <p>© 2026 E-Learning Platform. All rights reserved.</p>
    </footer>

</body>
</html>
