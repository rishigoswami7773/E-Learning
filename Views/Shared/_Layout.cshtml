<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-Learning</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            background: #f5f7fa;
        }

        /* Navbar */
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 8%;
            background: white;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-weight: 800;
            font-size: 22px;
            color: #1e293b;
            letter-spacing: -0.5px;
        }

        .nav-links {
            list-style: none;
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-links a {
            text-decoration: none;
            color: #475569;
            font-weight: 600;
            font-size: 15px;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: #2563eb;
        }

        .profile-btn {
            padding: 10px 20px;
            background: #2563eb;
            color: white !important;
            border-radius: 10px;
            font-weight: 700 !important;
            box-shadow: 0 4px 6px -1px rgb(37 99 235 / 0.2);
            transition: all 0.2s;
        }

        .profile-btn:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgb(37 99 235 / 0.3);
        }

        /* Hero */
        .hero {
            text-align: center;
            padding: 80px 20px;
            background: linear-gradient(135deg, #2b59ff, #4e73df);
            color: white;
        }

        .hero h1 {
            font-size: 42px;
            margin-bottom: 15px;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 30px;
        }

        .btn-primary {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            background: white;
            color: #2b59ff;
            font-weight: bold;
            cursor: pointer;
            margin: 10px;
        }

        .btn-secondary {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            background: #dfe6ff;
            color: #2b59ff;
            font-weight: bold;
            cursor: pointer;
            margin: 10px;
        }

        /* Features */
        .features {
            padding: 70px 8%;
            text-align: center;
        }

        .features h2 {
            font-size: 30px;
            margin-bottom: 10px;
        }

        .subtitle {
            color: gray;
            margin-bottom: 40px;
        }

        .feature-cards {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 12px;
            width: 300px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
        }

        .icon {
            font-size: 35px;
            margin-bottom: 15px;
        }

        /* CTA */
        .cta {
            text-align: center;
            padding: 60px 20px;
            background: #e9eef6;
        }

        .btn-dark {
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            background: #111827;
            color: white;
            font-weight: bold;
            cursor: pointer;
            margin-top: 20px;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 20px;
            background: #1f2937;
            color: white;
        }
    </style>
</head>

<body>

    <nav class="navbar">
        <div class="logo">🎓 E-Learning</div>
        <ul class="nav-links" style="align-items: center;">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Course" asp-action="Index">Courses</a></li>
            <li><a asp-controller="Home" asp-action="About">About</a></li>
            
            @if (Context.Session.GetInt32("UserId") != null)
            {
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <li><a asp-controller="Admin" asp-action="Dashboard" style="color: #2563eb; font-weight: 700;">Admin Panel</a></li>
                }
                else
                {
                    <li><a asp-controller="Student" asp-action="Dashboard" style="color: #2563eb; font-weight: 700;">My Dashboard</a></li>
                }

                <li style="display: flex; align-items: center; gap: 12px; padding: 6px 14px; background: #f8fafc; border-radius: 50px; border: 1px solid #e2e8f0; margin-left: 10px;">
                    <div style="width: 32px; height: 32px; background: #2563eb; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px;">
                        @(Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                    <div style="display: flex; flex-direction: column;">
                        <span style="font-size: 13px; font-weight: 700; color: #1e293b; line-height: 1;">@Context.Session.GetString("UserName")</span>
                        <a asp-controller="Users" asp-action="Logout" style="color: #ef4444; font-size: 10px; font-weight: 800; text-decoration: none; text-transform: uppercase; margin-top: 2px;">Logout</a>
                    </div>
                </li>
            }
            else
            {
                <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                <li><a asp-controller="Users" asp-action="Login" class="profile-btn">Sign In / Register</a></li>
            }
        </ul>
    </nav>

    @RenderBody()

    <!-- Footer -->
    <footer style="background: #0f172a; padding: 80px 8% 40px; color: white;">
        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 60px;">
            <div>
                <div class="logo" style="color: white; margin-bottom: 20px;">🎓 E-Learning</div>
                <p style="color: #94a3b8; line-height: 1.6; font-size: 14px; max-width: 300px;">
                    Empowering learners worldwide with high-quality, industry-relevant professional education.
                </p>
                <div style="display: flex; gap: 15px; margin-top: 25px;">
                    <a href="#" style="color: #94a3b8; font-size: 20px;"><i class="fab fa-facebook"></i></a>
                    <a href="#" style="color: #94a3b8; font-size: 20px;"><i class="fab fa-twitter"></i></a>
                    <a href="#" style="color: #94a3b8; font-size: 20px;"><i class="fab fa-linkedin"></i></a>
                    <a href="#" style="color: #94a3b8; font-size: 20px;"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
            <div>
                <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 25px;">Platform</h4>
                <ul style="list-style: none; padding: 0;">
                    <li style="margin-bottom: 12px;"><a asp-controller="Course" asp-action="Index"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">Browse Courses</a></li>
                    <li style="margin-bottom: 12px;"><a href="#"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">Instructors</a></li>
                    <li style="margin-bottom: 12px;"><a href="#"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">Certificates</a></li>
                </ul>
            </div>
            <div>
                <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 25px;">Company</h4>
                <ul style="list-style: none; padding: 0;">
                    <li style="margin-bottom: 12px;"><a asp-controller="Home" asp-action="About"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">About Us</a></li>
                    <li style="margin-bottom: 12px;"><a asp-controller="Home" asp-action="Contact"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">Contact Us</a></li>
                    <li style="margin-bottom: 12px;"><a asp-controller="Home" asp-action="Privacy"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">Privacy Policy</a></li>
                </ul>
            </div>
            <div>
                <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 25px;">Support</h4>
                <ul style="list-style: none; padding: 0;">
                    <li style="margin-bottom: 12px;"><a asp-controller="Home" asp-action="FAQ"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">Help Center</a></li>
                    <li style="margin-bottom: 12px;"><a href="#"
                            style="color: #94a3b8; text-decoration: none; font-size: 14px;">Status</a></li>
                </ul>
            </div>
        </div>
        <div
            style="border-top: 1px solid #1e293b; padding-top: 30px; text-align: center; color: #64748b; font-size: 14px;">
            <p>© @DateTime.Now.Year E-Learning Platform. All rights reserved.</p>
        </div>
    </footer>

</body>

</html>
