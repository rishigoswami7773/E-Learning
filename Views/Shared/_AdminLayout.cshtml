<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <!-- Modern Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">

    <!-- Robust Iconography -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <!-- Main stylesheet -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

<body>

    <div class="admin-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="logo-section">
                <div class="icon-box">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div>
                    <h2 style="font-size: 20px; margin: 0; font-weight: 600; background: none; color: white; -webkit-text-fill-color: white;">E-Learning</h2>
                    <span style="display: block; font-size: 11px; color: #9ca3af; margin-top: 2px;">Admin Panel</span>
                </div>
            </div>

            <nav>
                <a asp-controller="Admin" asp-action="Dashboard"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="fas fa-grip"></i> Dashboard
                </a>

                <a asp-controller="Admin" asp-action="Profile"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                    <i class="fas fa-user"></i> My Profile
                </a>

                <a asp-controller="Admin" asp-action="ManageUsers"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageUsers" ? "active" : "")">
                    <i class="fas fa-users"></i> Manage Users
                </a>

                <a asp-controller="Admin" asp-action="Courses"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Courses" ? "active" : "")">
                    <i class="fas fa-book"></i> Courses
                </a>

                <a asp-controller="Admin" asp-action="CourseApproval"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "CourseApproval" ? "active" : "")">
                    <i class="fas fa-check-circle"></i> Course Approval
                </a>

                <a asp-controller="Admin" asp-action="Payments"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Payments" ? "active" : "")">
                    <i class="far fa-credit-card"></i> Payments
                </a>

                <a asp-controller="Admin" asp-action="Analytics"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Analytics" ? "active" : "")">
                    <i class="fas fa-chart-simple"></i> Analytics
                </a>

                <a asp-controller="Admin" asp-action="ManageQuizzes"
                    class="@(new[]{"ManageQuizzes","ManageQuestions","AddQuestion","EditQuestion"}.Contains(ViewContext.RouteData.Values["Action"]?.ToString()) ? "active" : "")">
                    <i class="fas fa-circle-question"></i> Quizzes
                </a>

                <a asp-controller="Admin" asp-action="Settings"
                    class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "active" : "")">
                    <i class="fas fa-gear"></i> Settings
                </a>
            </nav>

            <div class="sidebar-footer">
                <a asp-controller="Users" asp-action="Logout">
                    <i class="fas fa-arrow-right-from-bracket"></i> Exit Admin
                </a>
            </div>
        </aside>

        <!-- Content Area -->
        <main class="admin-content">
            <header class="top-header">
                <div class="header-left">
                    <h1 style="font-size: 20px; font-weight: 700;">Admin Dashboard</h1>
                </div>

                <div class="header-right" style="display: flex; align-items: center; gap: 16px;">
                    <div style="font-size: 12px; color: #9ca3af; font-weight: 500; text-align: right; line-height: 1.2;">
                        Last updated<br>
                        <span style="font-weight: 700; color: #111827;">@DateTime.Now.ToString("M/d/yyyy, h:mm:ss tt")</span>
                    </div>
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: #3b82f6; color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; letter-spacing: 0.5px;">
                        AU
                    </div>
                </div>
            </header>

            <div class="main-body">
                <div style="margin-bottom: 24px;">
                    <h2 style="font-size: 28px; font-weight: 800; color: #111827; margin: 0; margin-bottom: 8px;">@(ViewData["Title"] ?? "Dashboard")</h2>
                    <p style="color: #6b7280; margin: 0; font-size: 15px;">Welcome back, Admin! Here's what's happening today.</p>
                </div>
                @RenderBody()
            </div>
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
