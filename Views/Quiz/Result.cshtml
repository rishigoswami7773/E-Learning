@{
    ViewData["Title"] = "Quiz Result";
    bool passed = ViewBag.Percentage >= 70;
}

<style>
    .result-container {
        padding: 60px 8%;
        max-width: 600px;
        margin: 0 auto;
        text-align: center;
    }

    .result-card {
        background: white;
        padding: 50px;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }

    .score-circle {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        margin: 0 auto 30px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: @(passed ? "#dcfce7" : "#fee2e2");
        color: @(passed ? "#15803d" : "#dc2626");
        border: 4px solid @(passed ? "#15803d" : "#dc2626");
    }

    .score-circle h2 {
        font-size: 40px;
        margin: 0;
    }

    .result-status {
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 10px;
        color: #111827;
    }

    .score-details {
        font-size: 16px;
        color: #6b7280;
        margin-bottom: 30px;
    }

    .btn-action {
        display: inline-block;
        padding: 12px 25px;
        border-radius: 8px;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s;
        margin: 10px;
    }

    .btn-cert {
        background: #2b59ff;
        color: white;
    }

    .btn-retry {
        background: #f3f4f6;
        color: #1f2937;
    }
</style>

<div class="result-container">
    <div class="result-card">
        <div class="score-circle">
            <h2>@Math.Round(ViewBag.Percentage)%</h2>
            <span>Score</span>
        </div>

        @if (passed)
        {
            <div class="result-status">🎉 Congratulations! You Passed.</div>
            <p class="score-details">You answered @ViewBag.Correct out of @ViewBag.Total questions correctly.</p>
            <a asp-action="Certificate" asp-route-quizId="@ViewBag.QuizId" class="btn-action btn-cert">Get Your Certificate →</a>
        }
        else
        {
            <div class="result-status">Better Luck Next Time!</div>
            <p class="score-details">You got @ViewBag.Correct/@ViewBag.Total. You need at least 70% to pass.</p>
            <a asp-action="TakeQuiz" asp-route-id="@ViewBag.QuizId" class="btn-action btn-retry">Try Again</a>
        }

        <br />
        <a asp-controller="Course" asp-action="Index" style="display:block; margin-top:20px; color:#6b7280; font-size:14px; text-decoration:none;">Back to Courses</a>
    </div>
</div>
